// ============================================================================
// SB1 REGIME FEATURE EXTRACTION v1.0
// Atlas Regime Intelligence — Sprint 088
// ============================================================================
// PURPOSE:
//   Extracts all 9 regime features required by the Atlas Nexus server-side
//   GBM Regime Activation Score (RAS) engine. Sends features via webhook
//   to /api/webhook/sb1-regime on every 5-minute bar close.
//
// ARCHITECTURE:
//   This script is a COMPANION to the main SB1 strategy (atlas_core.pine).
//   It does NOT execute trades. It computes and transmits regime features only.
//
//   The RAS is computed server-side in Atlas Nexus using the serialised
//   Sprint 087 GBM model. The server returns the RAS score and activation
//   decision back to the Observatory dashboard.
//
// FEATURES TRANSMITTED:
//   1. prev_day_range_atr   — Prior session range normalised by ATR14
//   2. prev_day_position    — Current price position within prior day range (0–1)
//   3. overnight_gap        — Overnight gap normalised by ATR14
//   4. chop14               — CHOP Index (14)
//   5. atr_expansion        — ATR14 / 20-bar ATR mean
//   6. vwap_dist            — (close − VWAP) / ATR14
//   7. ema_slope            — (EMA15 − EMA15[5]) / ATR14
//   8. ema_dist             — (close − EMA15) / ATR14
//   9. trend_persistence    — Consecutive bars on same side of EMA15
//
// GOVERNANCE:
//   - SB1 is LIVE ACCOUNT ONLY. No prop firm connection.
//   - This script is PAPER MODE only. No live execution.
//   - Webhook fires on every bar close (5-min chart, MNQ1!)
//   - Webhook token must match ATLAS_WEBHOOK_TOKEN in Atlas Nexus
//
// ============================================================================

//@version=5
indicator(title="SB1 Regime Features v1.0", 
          shorttitle="SB1-RF", 
          overlay=false,
          max_labels_count=10)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grp_webhook = "Webhook Settings"
i_webhook_url   = input.string("https://YOUR-ATLAS-NEXUS-URL/api/webhook/sb1-regime", 
                                "Atlas Nexus Webhook URL", group=grp_webhook)
i_webhook_token = input.string("YOUR_ATLAS_WEBHOOK_TOKEN", 
                                "Webhook Token", group=grp_webhook)
i_send_every    = input.int(1, "Send every N bars (1=every bar)", 
                             minval=1, maxval=10, group=grp_webhook)

grp_params = "Indicator Parameters"
i_atr_len       = input.int(14, "ATR Length",           minval=5, maxval=50, group=grp_params)
i_ema_len       = input.int(15, "EMA Length",           minval=5, maxval=50, group=grp_params)
i_chop_len      = input.int(14, "CHOP Index Length",    minval=5, maxval=50, group=grp_params)
i_atr_mean_len  = input.int(20, "ATR Mean Length",      minval=10, maxval=50, group=grp_params)
i_ema_slope_len = input.int(5,  "EMA Slope Lookback",   minval=2, maxval=20, group=grp_params)
i_trend_len     = input.int(20, "Trend Persistence Max",minval=5, maxval=50, group=grp_params)

grp_display = "Display"
i_show_table    = input.bool(true, "Show Feature Table", group=grp_display)

// ─── CORE CALCULATIONS ───────────────────────────────────────────────────────

// ATR
atr14 = ta.atr(i_atr_len)
atr_mean = ta.sma(atr14, i_atr_mean_len)

// EMA
ema15 = ta.ema(close, i_ema_len)

// CHOP Index
chop_high = ta.highest(high, i_chop_len)
chop_low  = ta.lowest(low, i_chop_len)
chop_range = chop_high - chop_low
chop_atr_sum = math.sum(ta.atr(1), i_chop_len)
chop14 = chop_range > 0 ? 100.0 * math.log10(chop_atr_sum / chop_range) / math.log10(i_chop_len) : 50.0

// VWAP
vwap_val = ta.vwap(hlc3)

// Previous day values
prev_day_high  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
prev_day_low   = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)
prev_day_close = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)
prev_day_range = prev_day_high - prev_day_low

// ─── FEATURE COMPUTATION ─────────────────────────────────────────────────────

// F1: Previous Day Range / ATR
f_pd_range_atr = atr14 > 0 ? prev_day_range / atr14 : 0.0

// F2: Previous Day Position (0=at low, 1=at high)
f_pd_position = prev_day_range > 0 ? (close - prev_day_low) / prev_day_range : 0.5

// F3: Overnight Gap / ATR
f_overnight_gap = atr14 > 0 ? (open - prev_day_close) / atr14 : 0.0

// F4: CHOP Index
f_chop = chop14

// F5: ATR Expansion Ratio
f_atr_expansion = atr_mean > 0 ? atr14 / atr_mean : 1.0

// F6: VWAP Distance / ATR (signed)
f_vwap_dist = atr14 > 0 ? (close - vwap_val) / atr14 : 0.0

// F7: EMA Slope / ATR
f_ema_slope = atr14 > 0 ? (ema15 - ema15[i_ema_slope_len]) / atr14 : 0.0

// F8: EMA Distance / ATR (signed)
f_ema_dist = atr14 > 0 ? (close - ema15) / atr14 : 0.0

// F9: Trend Persistence (consecutive bars on same side of EMA)
above_ema = close > ema15
var int consec_above = 0
var int consec_below = 0
consec_above := above_ema ? consec_above + 1 : 0
consec_below := not above_ema ? consec_below + 1 : 0
f_trend_persistence = above_ema ? consec_above : consec_below

// ─── PLOTS ───────────────────────────────────────────────────────────────────
plot(f_chop, title="CHOP14", color=color.new(color.yellow, 40), linewidth=1)
plot(f_atr_expansion * 10, title="ATR Exp ×10", color=color.new(color.teal, 40), linewidth=1)
hline(45, "CHOP Neutral", color=color.new(color.gray, 60), linestyle=hline.style_dotted)
hline(61.8, "CHOP Threshold", color=color.new(color.orange, 40), linestyle=hline.style_dashed)

// ─── FEATURE TABLE ───────────────────────────────────────────────────────────
if i_show_table and barstate.islast
    var table t = table.new(position.top_right, 2, 12,
                            bgcolor=color.new(color.black, 80),
                            border_color=color.new(color.gray, 50),
                            border_width=1, frame_color=color.new(color.gray, 30), frame_width=1)
    
    table.cell(t, 0, 0, "SB1 REGIME FEATURES", text_color=color.new(color.blue, 10), 
               text_size=size.small, bgcolor=color.new(color.navy, 60))
    table.cell(t, 1, 0, "VALUE", text_color=color.new(color.gray, 20), 
               text_size=size.small, bgcolor=color.new(color.navy, 60))
    
    feature_names  = array.from("F1 PD Range/ATR", "F2 PD Position", "F3 O/N Gap", 
                                 "F4 CHOP14", "F5 ATR Expansion", "F6 VWAP Dist",
                                 "F7 EMA Slope", "F8 EMA Dist", "F9 Trend Pers")
    feature_values = array.from(f_pd_range_atr, f_pd_position, f_overnight_gap,
                                 f_chop, f_atr_expansion, f_vwap_dist,
                                 f_ema_slope, f_ema_dist, float(f_trend_persistence))
    
    for i = 0 to 8
        table.cell(t, 0, i + 1, array.get(feature_names, i), 
                   text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.black, 80))
        table.cell(t, 1, i + 1, str.tostring(array.get(feature_values, i), "#.###"), 
                   text_color=color.new(color.aqua, 10), text_size=size.tiny, bgcolor=color.new(color.black, 80))
    
    // Timestamp row
    table.cell(t, 0, 10, "Bar Time", text_color=color.new(color.gray, 30), text_size=size.tiny, bgcolor=color.new(color.black, 80))
    table.cell(t, 1, 10, str.format_time(time, "HH:mm", "America/New_York"), 
               text_color=color.new(color.gray, 30), text_size=size.tiny, bgcolor=color.new(color.black, 80))
    
    // Webhook status
    table.cell(t, 0, 11, "Webhook", text_color=color.new(color.gray, 30), text_size=size.tiny, bgcolor=color.new(color.black, 80))
    table.cell(t, 1, 11, "ACTIVE", text_color=color.new(color.green, 10), text_size=size.tiny, bgcolor=color.new(color.black, 80))

// ─── WEBHOOK ALERT MESSAGE ───────────────────────────────────────────────────
// Alert message format — paste this into TradingView Alert → Message field:
// {
//   "token": "{{strategy.order.comment}}",
//   "schema_version": "sb1_regime_v1",
//   "bar_time": "{{time}}",
//   "symbol": "{{ticker}}",
//   "timeframe": "{{interval}}",
//   "close": {{close}},
//   "features": {
//     "prev_day_range_atr": {{plot("F1 PD Range/ATR")}},
//     "prev_day_position": {{plot("F2 PD Position")}},
//     "overnight_gap": {{plot("F3 O/N Gap")}},
//     "chop": {{plot("F4 CHOP14")}},
//     "atr_expansion": {{plot("F5 ATR Expansion")}},
//     "vwap_dist": {{plot("F6 VWAP Dist")}},
//     "ema_slope": {{plot("F7 EMA Slope")}},
//     "ema_dist": {{plot("F8 EMA Dist")}},
//     "trend_persistence": {{plot("F9 Trend Pers")}}
//   }
// }

// Alert condition — fires on every bar close
alertcondition(barstate.isconfirmed and bar_index % i_send_every == 0,
               title="SB1 Regime Features — Bar Close",
               message="SB1 REGIME FEATURES PAYLOAD — see alert message template in script comments")
