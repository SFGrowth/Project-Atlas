string  i_execution_mode        = input.string("PAPER",                    title="Execution Mode",          group=GRP_PROFILE, options=["PAPER","EVALUATION","FUNDED","LIVE"], tooltip="PAPER = simulation only. EVALUATION/FUNDED/LIVE require explicit arming.")
string  i_account_type          = input.string("PROP",                     title="Account Classification",  group=GRP_PROFILE, options=["PAPER","PROP","LIVE"], tooltip="Used by ARI for daily loss limit selection.")
float   i_dollar_risk           = input.float(800.0,                       title="Dollar Risk Per Trade ($)",group=GRP_PROFILE, minval=10.0, maxval=10000.0, step=50.0, tooltip="Maximum dollar loss if initial stop is hit. Contracts are calculated automatically from this value, the stop distance, and the point value. Never intentionally exceeded.")
float   i_point_value           = input.float(2.0,                         title="Instrument Point Value ($)",group=GRP_PROFILE, minval=0.5, step=0.5, tooltip="Dollar value per point per contract. MNQ = $2.00.")
int     i_max_contracts         = input.int(5,                             title="Maximum Contracts",       group=GRP_PROFILE, minval=1, maxval=20, tooltip="Hard ceiling on contract quantity regardless of risk calculation.")
