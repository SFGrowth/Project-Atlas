// ============================================================================
// ATLAS KERNEL — M-14 atlas_core.pine
// ============================================================================
// Version:   1.0.0
// Sprint:    073
// Module:    M-14
// Author:    Atlas Engineering
// Date:      2026-07-10
//
// MISSION:
//   The Atlas Kernel is the master orchestration layer of the entire Atlas
//   operating system. It is the single executable Pine Script that coordinates
//   every subsystem in the correct deterministic order.
//
//   The Kernel contains no trading logic.
//   It never evaluates market conditions.
//   It never generates trade ideas.
//   It never modifies risk.
//   It never verifies trades.
//   It only orchestrates the execution pipeline.
//
// PIPELINE (14 stages, executed in order on every completed bar):
//   1.  Configuration Update
//   2.  State Manager Refresh
//   3.  Market State Engine (M-03)
//   4.  Model A1 Evaluation (M-04)
//   5.  Model A3 Evaluation (M-05)
//   6.  Model B1 Evaluation (M-06)
//   7.  Atlas Decision Engine (M-07)
//   8.  Atlas Risk Intelligence (M-08)
//   9.  Trade Verification Layer (M-09)
//   10. Execution Engine (M-10)
//   11. Observatory Event Generation
//   12. Atlas Brain Update
//   13. Mission Control Update
//   14. Heartbeat
//
// FAIL-SAFE:
//   If any stage fails, execution stops safely. No partial execution.
//   No webhook generation on failure.
//
// DEPENDENCIES:
//   M-01: atlas_utils (library)
//   M-03: atlas_market_state_engine (library)
//   M-07: atlas_decision_engine (library)
//   M-08: atlas_risk_intelligence (library)
//   M-09: atlas_tvl (library)
//   M-02, M-04, M-05, M-06, M-10: Inlined (require global var mutations)
//
// ============================================================================

//@version=5
indicator("Atlas Kernel — M-14", overlay=true, max_labels_count=500, max_lines_count=100)

// ============================================================================
// SECTION 1: KERNEL VERSION & IDENTITY
// ============================================================================

string KERNEL_VERSION    = "1.0.0"
string KERNEL_MODULE     = "M-14"
string KERNEL_BUILD_DATE = "2026-07-10"
string KERNEL_SPRINT     = "073"

