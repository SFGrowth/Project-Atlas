// PipelineReport — one immutable record per completed bar
type PipelineReport
    // Identity
    int     bar_index_val
    int     ts_utc
    string  session
    int     pipeline_run_count

    // Stage Results
    bool    stage_config_ok
    bool    stage_state_ok
    bool    stage_mse_ok
    bool    stage_models_ok
    bool    stage_ade_ok
    bool    stage_ari_ok
    bool    stage_tvl_ok
    bool    stage_exec_ok

    // Market State Summary
    float   ema9
    float   ema21
    float   ema50
    float   atr14
    float   adx14
    string  ema_structure
    bool    mvc_003_active

    // Decision Summary
    bool    has_candidate
    string  winning_model
    float   winning_score
    string  confidence_level
    string  ranking_order

    // Risk Summary
    bool    ari_approved
    int     contracts
    float   allocated_risk
    float   risk_multiplier

    // TVL Summary
    bool    tvl_verified
    string  tvl_status
    string  tvl_blocking_rule

    // Execution Summary
    string  position_status
    float   current_pnl
    float   current_r

    // Performance
    int     pipeline_bars_elapsed
    bool    pipeline_failed
    string  failure_stage
    string  failure_reason

    // Statistics
    float   daily_pnl
    int     daily_trades
    float   total_pnl
    int     total_trades
    float   win_rate

// Kernel State
type KernelState
    int     pipeline_run_count
    int     last_run_bar
    bool    system_ready
    string  system_status
    int     heartbeat_count
    float   avg_pipeline_time
    float   worst_pipeline_time
    int     total_state_changes
    int     total_signals_generated
    int     total_trades_approved
    int     total_trades_rejected

