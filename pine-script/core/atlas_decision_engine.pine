// ATLAS TRADING SYSTEM v2.1
// Module: M-07 — Atlas Decision Engine (ADE)
// Sprint: 069
// Specification: APS v1.0 Section 3 | Pine Engineering Spec v1.0 Section 4 | ADE Spec v1.0
//
// PURPOSE:
//   Evaluates all TradeProposals generated by the execution models, calculates their
//   Edge Scores, ranks them, and produces a single deterministic CandidateModel.
//   If no model scores >= 60, produces NO_TRADE.
//
// RESPONSIBILITIES:
//   - Calculate 7-component Edge Score for each valid proposal
//   - Filter out proposals with Edge Score < 60
//   - Rank remaining proposals deterministically
//   - Resolve ties (C7 > C2 > C5)
//   - Generate DecisionReport for Observatory and Atlas Brain
//
// CONSTRAINTS:
//   - MUST NOT generate signals (only evaluates proposals)
//   - MUST NOT allocate capital (that is ARI's job)
//   - MUST be fully deterministic
// ============================================================================

//@version=5
library("atlas_decision_engine", overlay=false)

// We assume MarketState and TradeProposal are imported from their respective modules
// in the production environment. For this standalone file, we define the UDTs we produce.

// ============================================================================
// SECTION 1: USER DEFINED TYPES
// ============================================================================

// ---------------------------------------------------------------------------
// 1.1 CandidateModel — The winning model passed to ARI
// ---------------------------------------------------------------------------
export type CandidateModel
    bool    has_candidate
    string  model_id
    float   edge_score
    int     direction
    float   entry_price
    float   stop_price
    float   target_price
    float   risk_pts
    float   rr_ratio
    string  signal_basis

// ---------------------------------------------------------------------------
// 1.2 DecisionReport — The complete explanation for Observatory/Brain
// ---------------------------------------------------------------------------
export type DecisionReport
    string  decision_id         // Unique ID (e.g., "ADE-1718029300")
    int     ts_utc              // Decision timestamp
    string  winning_model       // "A1", "A3", "B1", or "NO_TRADE"
    float   winning_score       // Edge Score of winner
    string  ranking_order       // e.g., "B1(87.4) > A1(62.1) > A3(REJECTED)"
    string  rejection_reasons   // Comma-separated list of why losers were rejected
    string  confidence_level    // "HIGH" (>=80), "MEDIUM" (60-79), "LOW" (<60)
    
// ============================================================================
// SECTION 2: EDGE SCORE CALCULATION
// Calculates the 7-component Edge Score (0-100) for a given proposal.
// ============================================================================

// Component weights (APS / ADE Spec)
var float W_MARKET_ALIGNMENT    = 20.0
var float W_HISTORICAL_EXPECT   = 20.0
var float W_REGIME_MATCH        = 20.0
var float W_SESSION_MATCH       = 15.0
var float W_MVC_STRENGTH        = 15.0
var float W_BEHAVIOUR_CONF      = 5.0
var float W_PROD_RELIABILITY    = 5.0

// Note: Pine Script doesn't support passing MarketState UDT as a parameter to library 
// functions unless it's defined in the same file or imported. We use primitive parameters
// for the calculation functions to maximize compatibility and testability.

// @function Calculates C1: Market Alignment (0-20 points)
// @param ema_structure "BULL_ALIGNED", "BEAR_ALIGNED", "MIXED"
// @param adx14 ADX value
// @param direction Trade direction (1 or -1)
f_calc_c1(string ema_structure, float adx14, int direction) =>
    float score = 0.0
    // Full points if trend aligned with trade direction and ADX is strong
    if (direction == 1 and ema_structure == "BULL_ALIGNED") or (direction == -1 and ema_structure == "BEAR_ALIGNED")
        score := W_MARKET_ALIGNMENT
        if adx14 < 20
            score := score * 0.5 // Penalty for weak trend
    score

    score

// @function Calculates C2: Historical Expectancy (0-20 points)
// @param model_id "A1", "A3", "B1"
// @param current_pf The current rolling Profit Factor for this model
f_calc_c2(string model_id, float current_pf) =>
    float score = 0.0
    // Base score on Profit Factor thresholds
    if current_pf >= 2.0
        score := W_HISTORICAL_EXPECT
    else if current_pf >= 1.5
        score := W_HISTORICAL_EXPECT * 0.8
    else if current_pf >= 1.2
        score := W_HISTORICAL_EXPECT * 0.5
    else
        score := 0.0
    score

// @function Calculates C3: Regime Match (0-20 points)
// @param volatility_state "LOW" or "TRENDING"
// @param model_id "A1", "A3", "B1"
f_calc_c3(string volatility_state, string model_id) =>
    float score = 0.0
    // A3 and B1 require TRENDING regime. A1 prefers LOW/MEDIUM.
    if model_id == "A1" and volatility_state == "LOW"
        score := W_REGIME_MATCH
    else if (model_id == "A3" or model_id == "B1") and volatility_state == "TRENDING"
        score := W_REGIME_MATCH
    else
        score := W_REGIME_MATCH * 0.3 // Partial credit for mismatch
    score

// @function Calculates C4: Session Match (0-15 points)
// @param session Current session string
// @param model_id "A1", "A3", "B1"
f_calc_c4(string session, string model_id) =>
    float score = 0.0
    if model_id == "A1" and session == "PM_SESSION"
        score := W_SESSION_MATCH
    else if model_id == "A3" and session == "OVERNIGHT"
        score := W_SESSION_MATCH
    else if model_id == "B1" and session == "AM_SESSION"
        score := W_SESSION_MATCH
    score

// @function Calculates C5: MVC Strength (0-15 points)
// @param mvc_003_active Boolean flag
// @param model_id "A1", "A3", "B1"
f_calc_c5(bool mvc_003_active, string model_id) =>
    float score = 0.0
    if model_id == "B1" and mvc_003_active
        score := W_MVC_STRENGTH
    else if model_id != "B1"
        // Other models don't strictly require MVC, give baseline score
        score := W_MVC_STRENGTH * 0.5
    score

// @function Calculates C6: Behaviour Confidence (0-5 points)
// @param rolling_wr Rolling win rate (0.0 - 1.0)
f_calc_c6(float rolling_wr) =>
    float score = 0.0
    if rolling_wr >= 0.60
        score := W_BEHAVIOUR_CONF
    else if rolling_wr >= 0.40
        score := W_BEHAVIOUR_CONF * 0.5
    score

// @function Calculates C7: Production Reliability (0-5 points)
// @param model_id "A1", "A3", "B1"
f_calc_c7(string model_id) =>
    // Static historical PF scores
    float score = 0.0
    if model_id == "B1" // Highest historical PF
        score := W_PROD_RELIABILITY
    else if model_id == "A3"
        score := W_PROD_RELIABILITY * 0.8
    else if model_id == "A1"
        score := W_PROD_RELIABILITY * 0.6
    score

// ============================================================================
// SECTION 3: CORE EVALUATION FUNCTION
// ============================================================================

// Note: To compile as a standalone library, we must define TradeProposal locally
// or use primitive arrays. For Pine compilation verification, we will use a tuple
// return type for the core logic, which is cleaner than duplicating UDTs.

export f_calculate_edge_score(
     string model_id, 
     int direction,
     string ema_structure,
     float adx14,
     string volatility_state,
     string session,
     bool mvc_003_active,
     float current_pf,
     float rolling_wr) =>
    
    float c1 = f_calc_c1(ema_structure, adx14, direction)
    float c2 = f_calc_c2(model_id, current_pf)
    float c3 = f_calc_c3(volatility_state, model_id)
    float c4 = f_calc_c4(session, model_id)
    float c5 = f_calc_c5(mvc_003_active, model_id)
    float c6 = f_calc_c6(rolling_wr)
    float c7 = f_calc_c7(model_id)
    
    float total_score = c1 + c2 + c3 + c4 + c5 + c6 + c7
    total_score

// ============================================================================
// SECTION 4: RANKING AND SELECTION LOGIC
// ============================================================================

// @function Evaluates three models and returns the winning candidate parameters
// Returns a tuple of primitive values representing the CandidateModel and DecisionReport
export f_evaluate_candidates(
     // A1 parameters
     bool a1_has_signal, int a1_dir, float a1_entry, float a1_stop, float a1_target, float a1_risk, float a1_rr, string a1_basis, float a1_score,
     // A3 parameters
     bool a3_has_signal, int a3_dir, float a3_entry, float a3_stop, float a3_target, float a3_risk, float a3_rr, string a3_basis, float a3_score,
     // B1 parameters
     bool b1_has_signal, int b1_dir, float b1_entry, float b1_stop, float b1_target, float b1_risk, float b1_rr, string b1_basis, float b1_score,
     // Config
     float threshold) =>
    
    // Initialize winner variables
    bool   w_has_candidate = false
    string w_model_id      = "NO_TRADE"
    float  w_score         = 0.0
    int    w_dir           = 0
    float  w_entry         = na
    float  w_stop          = na
    float  w_target        = na
    float  w_risk          = na
    float  w_rr            = na
    string w_basis         = ""
    
    // Initialize report variables
    string r_ranking       = ""
    string r_reasons       = ""
    
    // Filter and Rank
    float max_score = 0.0
    string winner = ""
    
    // Check B1 (Highest priority in ties due to C7)
    if b1_has_signal and b1_score >= threshold
        if b1_score > max_score
            max_score := b1_score
            winner := "B1"
            
    // Check A3
    if a3_has_signal and a3_score >= threshold
        if a3_score > max_score
            max_score := a3_score
            winner := "A3"
            
    // Check A1
    if a1_has_signal and a1_score >= threshold
        if a1_score > max_score
            max_score := a1_score
            winner := "A1"
            
    // Assign winning parameters
    if winner == "B1"
        w_has_candidate := true
        w_model_id      := "B1"
        w_score         := b1_score
        w_dir           := b1_dir
        w_entry         := b1_entry
        w_stop          := b1_stop
        w_target        := b1_target
        w_risk          := b1_risk
        w_rr            := b1_rr
        w_basis         := b1_basis
    else if winner == "A3"
        w_has_candidate := true
        w_model_id      := "A3"
        w_score         := a3_score
        w_dir           := a3_dir
        w_entry         := a3_entry
        w_stop          := a3_stop
        w_target        := a3_target
        w_risk          := a3_risk
        w_rr            := a3_rr
        w_basis         := a3_basis
    else if winner == "A1"
        w_has_candidate := true
        w_model_id      := "A1"
        w_score         := a1_score
        w_dir           := a1_dir
        w_entry         := a1_entry
        w_stop          := a1_stop
        w_target        := a1_target
        w_risk          := a1_risk
        w_rr            := a1_rr
        w_basis         := a1_basis
        
    // Build Decision Report strings
    string b1_str = b1_has_signal ? "B1(" + str.tostring(b1_score, "#.#") + ")" : "B1(NO_SIGNAL)"
    string a3_str = a3_has_signal ? "A3(" + str.tostring(a3_score, "#.#") + ")" : "A3(NO_SIGNAL)"
    string a1_str = a1_has_signal ? "A1(" + str.tostring(a1_score, "#.#") + ")" : "A1(NO_SIGNAL)"
    
    r_ranking := b1_str + " | " + a3_str + " | " + a1_str
    
    if not w_has_candidate
        r_reasons := "No model met activation threshold (" + str.tostring(threshold) + ")"
    else
        r_reasons := "Winner: " + w_model_id + " (Score: " + str.tostring(w_score, "#.#") + ")"
        
    string r_confidence = w_score >= 80 ? "HIGH" : (w_score >= 60 ? "MEDIUM" : "LOW")
    string r_decision_id = "ADE-" + str.tostring(time)
    
    // Return all values as a tuple
    [w_has_candidate, w_model_id, w_score, w_dir, w_entry, w_stop, w_target, w_risk, w_rr, w_basis, r_decision_id, r_ranking, r_reasons, r_confidence]
