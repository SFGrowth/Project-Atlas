// ============================================================================
// ATLAS TRADING SYSTEM v2.1
// Module: M-02 — Atlas State Manager
// Sprint: 066
// Specification: APS v1.0 | Pine Engineering Spec v1.0
//
// PURPOSE:
//   Manages ALL persistent state in the Atlas system.
//   This is the ONLY module that declares var variables.
//   No other module may declare persistent state.
//
// RESPONSIBILITIES:
//   - All User Defined Types (UDTs) for Sprint 066 scope
//   - All var persistent variable declarations
//   - Daily reset logic (triggered at 09:30 ET)
//   - Session reset logic (overnight session tracking)
//   - Consecutive loss/win tracking
//   - Rolling array FIFO management
//   - State construction functions (RiskState, SessionState, etc.)
//   - Risk multiplier updates
//   - Circuit breaker management
//   - Per-model statistics tracking
//
// GOVERNING PRINCIPLE:
//   APS defines the behaviour. Pine Script implements the behaviour.
//   No engineering decision may modify the validated scientific specification.
// ============================================================================

//@version=5
library("atlas_state_manager", overlay=false)

// ============================================================================
// SECTION 1: USER DEFINED TYPES
// All UDTs required by M-00, M-01, M-02 scope (Sprint 066).
// Full UDT set including downstream types defined here for completeness.
// ============================================================================

// ---------------------------------------------------------------------------
// 1.1 RiskState — snapshot of current risk and position state
// Created by: M-02 | Consumed by: M-08, M-09
// ---------------------------------------------------------------------------
export type RiskState
    float   daily_pnl           // Cumulative P&L for current trading day
    int     daily_trade_count   // Number of completed trades today
    int     consecutive_losses  // Current streak of consecutive losses
    int     consecutive_wins    // Current streak of consecutive wins
    float   risk_multiplier     // Current active risk multiplier (0.25–2.0)
    bool    circuit_breaker     // true = all trading halted
    bool    active_position     // true = a position is currently open
    float   equity_peak         // All-time highest equity value
    float   current_drawdown    // equity_peak - current_equity
    float   base_risk           // Current base risk per trade ($)
    int     pause_until_bar     // Bar index after which trading resumes

// ---------------------------------------------------------------------------
// 1.2 SessionState — snapshot of current session tracking
// Created by: M-02 | Consumed by: M-03, M-04, M-05, M-06
// ---------------------------------------------------------------------------
export type SessionState
    bool    is_new_day              // true on first RTH bar of the day
    bool    is_new_session          // true on first bar of any session transition
    int     current_day_bar         // Bar count within current trading day
    float   day_open_price          // Opening price of the current RTH session
    float   ov_session_high         // Overnight session high
    float   ov_session_low          // Overnight session low
    float   ov_session_open         // Overnight session open
    float   ov_session_close        // Overnight session close (= RTH open)
    int     ov_session_direction    // 1=Bullish, -1=Bearish, 0=Neutral

// ---------------------------------------------------------------------------
// 1.3 DailyStatistics — all-time and rolling performance statistics
// Created by: M-02 | Consumed by: M-07, M-12, M-13
// ---------------------------------------------------------------------------
export type DailyStatistics
    int     total_trades        // All-time completed trades
    int     total_wins
    int     total_losses
    float   all_time_pnl
    float   gross_wins
    float   gross_losses
    float   profit_factor       // gross_wins / gross_losses
    float   win_rate            // total_wins / total_trades
    float   avg_win
    float   avg_loss
    float   expectancy          // (win_rate * avg_win) - ((1-win_rate) * avg_loss)
    float   rolling_pf_20       // Profit Factor over last 20 trades
    float   rolling_wr_20       // Win Rate over last 20 trades

// ---------------------------------------------------------------------------
// 1.4 PortfolioState — per-model and portfolio-level statistics
// Created by: M-02 | Consumed by: M-07, M-13
// ---------------------------------------------------------------------------
export type PortfolioState
    int     a1_trades
    float   a1_gross_wins
    float   a1_gross_losses
    float   a1_pf
    float   a1_wr
    int     a3_trades
    float   a3_gross_wins
    float   a3_gross_losses
    float   a3_pf
    float   a3_wr
    int     b1_trades
    float   b1_gross_wins
    float   b1_gross_losses
    float   b1_pf
    float   b1_wr
    float   portfolio_pf
    float   portfolio_wr
    float   max_drawdown
    float   sharpe_ratio

// ---------------------------------------------------------------------------
// 1.5 TradeProposal — a model's proposed trade
// Created by: M-04, M-05, M-06 | Consumed by: M-07
// Defined here so M-02 can reference it in state update functions
// ---------------------------------------------------------------------------
export type TradeProposal
    string  model_id
    bool    has_signal
    int     direction
    float   entry_price
    float   stop_price
    float   target_price
    float   risk_pts
    float   rr_ratio
    string  signal_basis
    string  rejection_reason

// ---------------------------------------------------------------------------
// 1.6 ApprovedTrade — ARI-approved trade ready for TVL
// Created by: M-08 | Consumed by: M-09
// Defined here for state update functions
// ---------------------------------------------------------------------------
export type ApprovedTrade
    bool    is_approved
    string  model_id
    float   edge_score
    int     direction
    float   entry_price
    float   stop_price
    float   target_price
    float   risk_pts
    float   rr_ratio
    int     contracts
    float   actual_risk
    float   risk_multiplier
    string  ari_rule_applied
    string  rejection_reason
    string  signal_id

// ============================================================================
// SECTION 2: PERSISTENT VARIABLE DECLARATIONS
// ALL var declarations in the Atlas system live here and ONLY here.
// ============================================================================

// ---------------------------------------------------------------------------
// 2.1 Risk & Position State
// ---------------------------------------------------------------------------
var float   v_daily_pnl             = 0.0
var int     v_daily_trade_count     = 0
var int     v_consecutive_losses    = 0
var int     v_consecutive_wins      = 0
var float   v_risk_multiplier       = 1.0
var bool    v_circuit_breaker       = false
var bool    v_active_position       = false
var float   v_equity_peak           = 100000.0  // Default initial capital; overridden at runtime
var float   v_base_risk             = 800.0     // Overridden by i_base_risk from M-00
var int     v_pause_until_bar       = 0

// ---------------------------------------------------------------------------
// 2.2 Session & Day State
// ---------------------------------------------------------------------------
var float   v_ov_session_high       = na
var float   v_ov_session_low        = na
var float   v_ov_session_open       = na
var float   v_ov_session_close      = na
var int     v_ov_session_direction  = 0
var float   v_day_open_price        = na
var int     v_current_day_bar       = 0
var bool    v_was_rth_prev_bar      = false
var bool    v_was_overnight_prev_bar = false
var int     v_prev_hour             = -1
var int     v_prev_minute           = -1

// ---------------------------------------------------------------------------
// 2.3 All-Time Performance Statistics
// ---------------------------------------------------------------------------
var int     v_total_trades          = 0
var int     v_total_wins            = 0
var float   v_all_time_pnl          = 0.0
var float   v_gross_wins            = 0.0
var float   v_gross_losses          = 0.0
var float   v_max_drawdown          = 0.0

// ---------------------------------------------------------------------------
// 2.4 Per-Model Counters
// ---------------------------------------------------------------------------
var int     v_a1_trades             = 0
var float   v_a1_gross_wins         = 0.0
var float   v_a1_gross_losses       = 0.0
var int     v_a3_trades             = 0
var float   v_a3_gross_wins         = 0.0
var float   v_a3_gross_losses       = 0.0
var int     v_b1_trades             = 0
var float   v_b1_gross_wins         = 0.0
var float   v_b1_gross_losses       = 0.0

// ---------------------------------------------------------------------------
// 2.5 Duplicate Signal Prevention
// ---------------------------------------------------------------------------
var string  v_last_signal_id        = ""
var int     v_last_signal_bar       = 0

// ---------------------------------------------------------------------------
// 2.6 Rolling Arrays (FIFO, max 20 trades for drift detection)
// ---------------------------------------------------------------------------
var array<float>  v_rolling_pnl     = array.new<float>(0)   // Max size: 20
var array<string> v_trade_history   = array.new<string>(0)  // Max size: 50, FIFO

// ============================================================================
// SECTION 3: DAILY RESET LOGIC
// Triggered on the first bar of each RTH session (09:30 ET).
// ============================================================================

// Detects the first bar of a new RTH session
// Uses the hour/minute in the chart's timezone (must be set to America/New_York)
f_detect_new_rth_day() =>
    int h = hour(time, "America/New_York")
    int m = minute(time, "America/New_York")
    bool is_rth_open_bar = (h == 9 and m == 30)
    bool was_not_rth     = not v_was_rth_prev_bar
    is_rth_open_bar and was_not_rth

// Detects the first bar of the overnight session (18:00 ET)
f_detect_overnight_open() =>
    int h = hour(time, "America/New_York")
    int m = minute(time, "America/New_York")
    bool is_overnight_open = (h == 18 and m == 0)
    bool was_not_overnight = not v_was_overnight_prev_bar
    is_overnight_open and was_not_overnight

// Performs the daily reset on RTH open
// Resets ONLY the daily variables — all-time stats and consecutive counters persist
export f_daily_reset(float rth_open_price) =>
    v_daily_pnl         := 0.0
    v_daily_trade_count := 0
    v_current_day_bar   := 0
    v_day_open_price    := rth_open_price
    // NOTE: v_consecutive_losses, v_consecutive_wins, v_circuit_breaker,
    //       v_equity_peak, v_base_risk, all v_total_* — NOT reset daily

// Performs the overnight session reset
// Captures the overnight open price and resets overnight tracking
export f_overnight_reset(float overnight_open_price) =>
    v_ov_session_open      := overnight_open_price
    v_ov_session_high      := overnight_open_price
    v_ov_session_low       := overnight_open_price
    v_ov_session_close     := overnight_open_price
    v_ov_session_direction := 0

// ============================================================================
// SECTION 4: SESSION TRACKING UPDATES
// Called on every bar to maintain overnight and day session state.
// ============================================================================

// Updates overnight session high/low/close on every overnight bar
export f_update_overnight_session(float bar_high, float bar_low, float bar_close) =>
    if not na(v_ov_session_high)
        v_ov_session_high  := math.max(v_ov_session_high, bar_high)
        v_ov_session_low   := math.min(v_ov_session_low, bar_low)
        v_ov_session_close := bar_close

// Finalises the overnight session direction at RTH open
// Called once per day on the RTH open bar
export f_finalise_overnight_direction() =>
    if not na(v_ov_session_open) and not na(v_ov_session_close)
        float ov_change = v_ov_session_close - v_ov_session_open
        if ov_change > 0
            v_ov_session_direction := 1
        else if ov_change < 0
            v_ov_session_direction := -1
        else
            v_ov_session_direction := 0

// Increments the day bar counter on every RTH bar
export f_increment_day_bar() =>
    v_current_day_bar := v_current_day_bar + 1

// ============================================================================
// SECTION 5: CONSECUTIVE LOSS/WIN TRACKING
// Called after every completed trade exit.
// ============================================================================

// Updates consecutive win/loss counters after a trade completes
// trade_pnl > 0 = win, trade_pnl <= 0 = loss
export f_update_consecutive_tracking(float trade_pnl) =>
    bool is_win = trade_pnl > 0.0
    if is_win
        v_consecutive_losses := 0
        v_consecutive_wins   := v_consecutive_wins + 1
    else
        v_consecutive_wins   := 0
        v_consecutive_losses := v_consecutive_losses + 1

// ============================================================================
// SECTION 6: RISK MULTIPLIER AND CIRCUIT BREAKER MANAGEMENT
// Implements ARI rules R3 (Caution), R4 (Pause), R5 (Circuit Breaker),
// and R6 (Compound) per APS v1.0 Section 5.
// ============================================================================

// Updates the risk multiplier based on current consecutive loss/win state
// Called after every trade exit and on every bar for circuit breaker check
export f_update_risk_multiplier(float caution_mult, float compound_mult, float daily_pnl,
                                 float daily_limit, float trailing_dd_limit,
                                 float equity_peak, float current_equity,
                                 int pause_bars) =>
    // R5: Circuit Breaker — daily loss limit or trailing drawdown limit
    float active_daily_limit = daily_limit  // Caller passes the correct limit (live or prop)
    float current_drawdown   = equity_peak - current_equity

    if daily_pnl <= active_daily_limit or current_drawdown >= math.abs(trailing_dd_limit)
        v_circuit_breaker  := true
        v_risk_multiplier  := 0.0
    else if v_circuit_breaker
        // Circuit breaker remains active until manually reset (session end)
        v_risk_multiplier := 0.0
    else if v_consecutive_losses >= 3
        // R4: Pause — 3 consecutive losses triggers a pause period
        v_pause_until_bar := bar_index + pause_bars
        v_risk_multiplier := 0.5  // Reduced risk during pause period
    else if bar_index < v_pause_until_bar
        // Still within pause period
        v_risk_multiplier := 0.5
    else if v_consecutive_losses == 2
        // R3: Caution — 2 consecutive losses reduces risk
        v_risk_multiplier := caution_mult
    else if v_consecutive_wins >= 3
        // R6: Compound — winning streak increases risk slightly
        v_risk_multiplier := compound_mult
    else
        // Normal operating state
        v_risk_multiplier := 1.0

// Resets the circuit breaker — called at start of new trading day
// Only resets if the daily loss was not catastrophic (>2x daily limit)
export f_reset_circuit_breaker_if_eligible(float yesterday_pnl, float daily_limit) =>
    if yesterday_pnl > daily_limit * 2.0
        // Catastrophic loss — circuit breaker remains active
        v_circuit_breaker := true
    else
        v_circuit_breaker := false

// Updates the equity peak tracker
export f_update_equity_peak(float current_equity) =>
    if current_equity > v_equity_peak
        v_equity_peak := current_equity

// ============================================================================
// SECTION 7: TRADE COMPLETION UPDATES
// Called after every trade exit to update all statistics.
// ============================================================================

// Records a completed trade and updates all statistics
// model_id: "A1" | "A3" | "B1"
// trade_pnl: dollar P&L of the completed trade
export f_record_trade_completion(string model_id, float trade_pnl, string signal_id) =>
    // Update daily counters
    v_daily_pnl         := v_daily_pnl + trade_pnl
    v_daily_trade_count := v_daily_trade_count + 1

    // Update all-time statistics
    v_total_trades  := v_total_trades + 1
    v_all_time_pnl  := v_all_time_pnl + trade_pnl

    if trade_pnl > 0
        v_total_wins  := v_total_wins + 1
        v_gross_wins  := v_gross_wins + trade_pnl
    else
        v_gross_losses := v_gross_losses + math.abs(trade_pnl)

    // Update per-model statistics
    if model_id == "A1"
        v_a1_trades := v_a1_trades + 1
        if trade_pnl > 0
            v_a1_gross_wins   := v_a1_gross_wins + trade_pnl
        else
            v_a1_gross_losses := v_a1_gross_losses + math.abs(trade_pnl)
    else if model_id == "A3"
        v_a3_trades := v_a3_trades + 1
        if trade_pnl > 0
            v_a3_gross_wins   := v_a3_gross_wins + trade_pnl
        else
            v_a3_gross_losses := v_a3_gross_losses + math.abs(trade_pnl)
    else if model_id == "B1"
        v_b1_trades := v_b1_trades + 1
        if trade_pnl > 0
            v_b1_gross_wins   := v_b1_gross_wins + trade_pnl
        else
            v_b1_gross_losses := v_b1_gross_losses + math.abs(trade_pnl)

    // Update rolling P&L array (FIFO, max 20)
    array.push(v_rolling_pnl, trade_pnl)
    if array.size(v_rolling_pnl) > 20
        array.shift(v_rolling_pnl)

    // Update trade history (FIFO, max 50)
    string trade_record = signal_id + ":" + str.tostring(trade_pnl, "#.00")
    array.push(v_trade_history, trade_record)
    if array.size(v_trade_history) > 50
        array.shift(v_trade_history)

    // Update consecutive tracking
    f_update_consecutive_tracking(trade_pnl)

    // Clear active position flag
    v_active_position := false

// Records a trade entry (sets active position flag and duplicate prevention)
export f_record_trade_entry(string signal_id) =>
    v_active_position   := true
    v_last_signal_id    := signal_id
    v_last_signal_bar   := bar_index

// ============================================================================
// SECTION 8: STATE CONSTRUCTION FUNCTIONS
// These functions build UDT snapshots from the current persistent variable state.
// Called by M-14 atlas_core on every bar to pass state to downstream modules.
// ============================================================================

// Constructs and returns the current RiskState snapshot
export f_build_risk_state(float base_risk) =>
    float current_equity = strategy.equity  // Available in strategy context
    float drawdown       = v_equity_peak - current_equity

    RiskState.new(
         daily_pnl          = v_daily_pnl,
         daily_trade_count  = v_daily_trade_count,
         consecutive_losses = v_consecutive_losses,
         consecutive_wins   = v_consecutive_wins,
         risk_multiplier    = v_risk_multiplier,
         circuit_breaker    = v_circuit_breaker,
         active_position    = v_active_position,
         equity_peak        = v_equity_peak,
         current_drawdown   = drawdown,
         base_risk          = base_risk,
         pause_until_bar    = v_pause_until_bar)

// Constructs and returns the current SessionState snapshot
export f_build_session_state(bool is_new_day, bool is_new_session) =>
    SessionState.new(
         is_new_day             = is_new_day,
         is_new_session         = is_new_session,
         current_day_bar        = v_current_day_bar,
         day_open_price         = v_day_open_price,
         ov_session_high        = v_ov_session_high,
         ov_session_low         = v_ov_session_low,
         ov_session_open        = v_ov_session_open,
         ov_session_close       = v_ov_session_close,
         ov_session_direction   = v_ov_session_direction)

// Constructs and returns the current DailyStatistics snapshot
export f_build_daily_statistics() =>
    int    total_losses = v_total_trades - v_total_wins
    float  win_rate     = v_total_trades > 0 ? float(v_total_wins) / float(v_total_trades) : 0.0
    float  avg_win      = v_total_wins > 0 ? v_gross_wins / float(v_total_wins) : 0.0
    float  avg_loss     = total_losses > 0 ? v_gross_losses / float(total_losses) : 0.0
    float  pf           = v_gross_losses > 0 ? v_gross_wins / v_gross_losses : (v_gross_wins > 0 ? 999.0 : 0.0)
    float  expectancy   = (win_rate * avg_win) - ((1.0 - win_rate) * avg_loss)

    // Rolling 20-trade statistics
    float  rolling_pf   = 0.0
    float  rolling_wr   = 0.0
    int    n_rolling    = array.size(v_rolling_pnl)
    if n_rolling > 0
        float rw = 0.0
        float rl = 0.0
        int   rw_count = 0
        for i = 0 to n_rolling - 1
            float v = array.get(v_rolling_pnl, i)
            if v > 0
                rw += v
                rw_count += 1
            else
                rl += math.abs(v)
        rolling_pf := rl > 0 ? rw / rl : (rw > 0 ? 999.0 : 0.0)
        rolling_wr := float(rw_count) / float(n_rolling)

    DailyStatistics.new(
         total_trades   = v_total_trades,
         total_wins     = v_total_wins,
         total_losses   = total_losses,
         all_time_pnl   = v_all_time_pnl,
         gross_wins     = v_gross_wins,
         gross_losses   = v_gross_losses,
         profit_factor  = pf,
         win_rate       = win_rate,
         avg_win        = avg_win,
         avg_loss       = avg_loss,
         expectancy     = expectancy,
         rolling_pf_20  = rolling_pf,
         rolling_wr_20  = rolling_wr)

// Constructs and returns the current PortfolioState snapshot
export f_build_portfolio_state() =>
    float a1_pf = v_a1_gross_losses > 0 ? v_a1_gross_wins / v_a1_gross_losses : (v_a1_gross_wins > 0 ? 999.0 : 0.0)
    float a3_pf = v_a3_gross_losses > 0 ? v_a3_gross_wins / v_a3_gross_losses : (v_a3_gross_wins > 0 ? 999.0 : 0.0)
    float b1_pf = v_b1_gross_losses > 0 ? v_b1_gross_wins / v_b1_gross_losses : (v_b1_gross_wins > 0 ? 999.0 : 0.0)

    float total_gross_wins   = v_a1_gross_wins + v_a3_gross_wins + v_b1_gross_wins
    float total_gross_losses = v_a1_gross_losses + v_a3_gross_losses + v_b1_gross_losses
    int   total_trades       = v_a1_trades + v_a3_trades + v_b1_trades
    float portfolio_pf       = total_gross_losses > 0 ? total_gross_wins / total_gross_losses : (total_gross_wins > 0 ? 999.0 : 0.0)
    float portfolio_wr       = total_trades > 0 ? float(v_total_wins) / float(total_trades) : 0.0

    float current_equity     = strategy.equity
    float drawdown           = v_equity_peak - current_equity

    PortfolioState.new(
         a1_trades       = v_a1_trades,
         a1_gross_wins   = v_a1_gross_wins,
         a1_gross_losses = v_a1_gross_losses,
         a1_pf           = a1_pf,
         a1_wr           = v_a1_trades > 0 ? float(v_total_wins) / float(v_a1_trades) : 0.0,
         a3_trades       = v_a3_trades,
         a3_gross_wins   = v_a3_gross_wins,
         a3_gross_losses = v_a3_gross_losses,
         a3_pf           = a3_pf,
         a3_wr           = v_a3_trades > 0 ? float(v_total_wins) / float(v_a3_trades) : 0.0,
         b1_trades       = v_b1_trades,
         b1_gross_wins   = v_b1_gross_wins,
         b1_gross_losses = v_b1_gross_losses,
         b1_pf           = b1_pf,
         b1_wr           = v_b1_trades > 0 ? float(v_total_wins) / float(v_b1_trades) : 0.0,
         portfolio_pf    = portfolio_pf,
         portfolio_wr    = portfolio_wr,
         max_drawdown    = v_max_drawdown,
         sharpe_ratio    = 0.0)  // Calculated by Observatory module

// ============================================================================
// SECTION 9: DUPLICATE SIGNAL DETECTION
// Prevents the same signal from firing twice on consecutive bars.
// ============================================================================

// Returns true if the given signal_id is a duplicate of the last signal
export f_is_duplicate_signal(string signal_id) =>
    signal_id == v_last_signal_id and bar_index == v_last_signal_bar + 1

// Returns the last signal ID (for TVL verification)
export f_get_last_signal_id() =>
    v_last_signal_id

// ============================================================================
// SECTION 10: MAIN BAR EXECUTION
// Called by M-14 atlas_core on every bar to update all session state.
// This section handles the bar-by-bar state machine.
// ============================================================================

// Detects session transitions and performs appropriate resets
// Returns [is_new_rth_day, is_new_session]
export f_process_bar_state() =>
    int  h = hour(time, "America/New_York")
    int  m = minute(time, "America/New_York")

    bool is_rth_now       = (h == 9 and m >= 30) or (h >= 10 and h <= 15) or (h == 16 and m == 0)
    bool is_overnight_now = h >= 18 or h < 9 or (h == 9 and m < 30)

    // Detect new RTH day (transition from non-RTH to RTH open)
    bool is_new_rth_day   = (h == 9 and m == 30) and not v_was_rth_prev_bar

    // Detect new overnight session (transition from RTH to overnight)
    bool is_new_overnight = (h == 18 and m == 0) and not v_was_overnight_prev_bar

    // Detect any session transition
    bool is_new_session   = is_new_rth_day or is_new_overnight

    // Perform resets on session transitions
    if is_new_rth_day
        f_finalise_overnight_direction()
        f_daily_reset(close)

    if is_new_overnight
        f_overnight_reset(close)

    // Update overnight session tracking on overnight bars
    if is_overnight_now and not is_new_overnight
        f_update_overnight_session(high, low, close)

    // Increment day bar counter on RTH bars
    if is_rth_now
        f_increment_day_bar()

    // Update previous bar session flags
    v_was_rth_prev_bar      := is_rth_now
    v_was_overnight_prev_bar := is_overnight_now
    v_prev_hour             := h
    v_prev_minute           := m

    [is_new_rth_day, is_new_session]

// ============================================================================
// SECTION 11: DEBUG VERIFICATION OUTPUTS
// Renders a debug table on the chart to verify all state transitions.
// Only active when debug_mode is enabled.
// ============================================================================

var table state_table = table.new(position.bottom_right, 2, 20,
     bgcolor      = color.new(color.maroon, 80),
     border_color = color.new(color.red, 50),
     border_width = 1)

// Call f_process_bar_state on every bar to maintain state
[_is_new_day, _is_new_session] = f_process_bar_state()

if barstate.islast
    int  h_et = hour(time, "America/New_York")
    int  m_et = minute(time, "America/New_York")

    table.cell(state_table, 0, 0,  "M-02: State Manager",                   text_color=color.yellow, text_size=size.small)
    table.cell(state_table, 1, 0,  "Current Value",                          text_color=color.yellow, text_size=size.small)
    table.cell(state_table, 0, 1,  "Daily P&L",                              text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 1,  str.tostring(v_daily_pnl, "#.00"),        text_color=v_daily_pnl >= 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(state_table, 0, 2,  "Daily Trades",                           text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 2,  str.tostring(v_daily_trade_count),        text_color=color.aqua,   text_size=size.tiny)
    table.cell(state_table, 0, 3,  "Consec Losses",                          text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 3,  str.tostring(v_consecutive_losses),       text_color=v_consecutive_losses >= 2 ? color.orange : color.green, text_size=size.tiny)
    table.cell(state_table, 0, 4,  "Consec Wins",                            text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 4,  str.tostring(v_consecutive_wins),         text_color=color.green,  text_size=size.tiny)
    table.cell(state_table, 0, 5,  "Risk Multiplier",                        text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 5,  str.tostring(v_risk_multiplier, "#.00"),  text_color=v_risk_multiplier < 1.0 ? color.orange : color.green, text_size=size.tiny)
    table.cell(state_table, 0, 6,  "Circuit Breaker",                        text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 6,  v_circuit_breaker ? "ACTIVE" : "OFF",     text_color=v_circuit_breaker ? color.red : color.green, text_size=size.tiny)
    table.cell(state_table, 0, 7,  "Active Position",                        text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 7,  v_active_position ? "YES" : "NO",         text_color=v_active_position ? color.yellow : color.gray, text_size=size.tiny)
    table.cell(state_table, 0, 8,  "Day Bar Count",                          text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 8,  str.tostring(v_current_day_bar),          text_color=color.aqua,   text_size=size.tiny)
    table.cell(state_table, 0, 9,  "Day Open Price",                         text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 9,  na(v_day_open_price) ? "N/A" : str.tostring(v_day_open_price, "#.00"), text_color=color.aqua, text_size=size.tiny)
    table.cell(state_table, 0, 10, "OV Direction",                           text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 10, v_ov_session_direction == 1 ? "BULL" : v_ov_session_direction == -1 ? "BEAR" : "NEUTRAL", text_color=v_ov_session_direction == 1 ? color.green : v_ov_session_direction == -1 ? color.red : color.gray, text_size=size.tiny)
    table.cell(state_table, 0, 11, "OV High",                                text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 11, na(v_ov_session_high) ? "N/A" : str.tostring(v_ov_session_high, "#.00"), text_color=color.aqua, text_size=size.tiny)
    table.cell(state_table, 0, 12, "OV Low",                                 text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 12, na(v_ov_session_low) ? "N/A" : str.tostring(v_ov_session_low, "#.00"), text_color=color.aqua, text_size=size.tiny)
    table.cell(state_table, 0, 13, "Total Trades",                           text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 13, str.tostring(v_total_trades),             text_color=color.aqua,   text_size=size.tiny)
    table.cell(state_table, 0, 14, "All-Time P&L",                           text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 14, str.tostring(v_all_time_pnl, "#.00"),     text_color=v_all_time_pnl >= 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(state_table, 0, 15, "Rolling PnL Array Size",                 text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 15, str.tostring(array.size(v_rolling_pnl)),  text_color=color.aqua,   text_size=size.tiny)
    table.cell(state_table, 0, 16, "Last Signal ID",                         text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 16, str.length(v_last_signal_id) > 0 ? v_last_signal_id : "NONE", text_color=color.aqua, text_size=size.tiny)
    table.cell(state_table, 0, 17, "Pause Until Bar",                        text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 17, str.tostring(v_pause_until_bar),          text_color=bar_index < v_pause_until_bar ? color.orange : color.gray, text_size=size.tiny)
    table.cell(state_table, 0, 18, "New RTH Day",                            text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 18, _is_new_day ? "YES" : "NO",               text_color=_is_new_day ? color.yellow : color.gray, text_size=size.tiny)
    table.cell(state_table, 0, 19, "Current Hour ET",                        text_color=color.white,  text_size=size.tiny)
    table.cell(state_table, 1, 19, str.format("{0,number,00}:{1,number,00}", h_et, m_et), text_color=color.aqua, text_size=size.tiny)
