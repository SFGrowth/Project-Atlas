// ============================================================================
// ATLAS TRADING SYSTEM v2.1
// Module: M-00 — Atlas Configuration
// Sprint: 066
// Specification: APS v1.0 | Pine Engineering Spec v1.0
//
// PURPOSE:
//   Single source of truth for all user-configurable parameters.
//   No production values may be hard-coded in any other module.
//   All inputs are grouped into logical TradingView sections.
//
// GOVERNING PRINCIPLE:
//   APS defines the behaviour. Pine Script implements the behaviour.
//   No engineering decision may modify the validated scientific specification.
// ============================================================================

//@version=5
indicator("Atlas Configuration — M-00", overlay=false)

// ============================================================================
// SECTION 1: ACCOUNT CONFIGURATION
// ============================================================================

var string GRP_ACCOUNT = "Account Configuration"

i_account_type = input.string(
     defval   = "LIVE",
     title    = "Account Type",
     options  = ["LIVE", "PROP"],
     tooltip  = "LIVE: higher risk tolerance. PROP: strict drawdown limits enforced.",
     group    = GRP_ACCOUNT)

i_base_risk = input.float(
     defval   = 800.0,
     title    = "Base Risk per Trade ($)",
     minval   = 100.0,
     maxval   = 5000.0,
     step     = 100.0,
     tooltip  = "Dollar risk per trade before ARI multiplier is applied. APS validated at $800.",
     group    = GRP_ACCOUNT)

i_max_contracts = input.int(
     defval   = 10,
     title    = "Maximum Contracts",
     minval   = 1,
     maxval   = 10,
     tooltip  = "Hard ceiling on contract count regardless of risk calculation.",
     group    = GRP_ACCOUNT)

i_point_value = input.float(
     defval   = 2.0,
     title    = "Point Value ($)",
     minval   = 0.25,
     maxval   = 50.0,
     step     = 0.25,
     tooltip  = "Dollar value per point per contract. MNQ = $2.00. NQ = $20.00.",
     group    = GRP_ACCOUNT)

// ============================================================================
// SECTION 2: DAILY RISK LIMITS
// ============================================================================

var string GRP_RISK = "Daily Risk Limits"

i_daily_loss_limit_live = input.float(
     defval   = -2000.0,
     title    = "Daily Loss Limit — Live ($)",
     minval   = -10000.0,
     maxval   = -100.0,
     step     = 100.0,
     tooltip  = "Circuit breaker triggers when daily P&L reaches this level (Live account).",
     group    = GRP_RISK)

i_daily_loss_limit_prop = input.float(
     defval   = -1500.0,
     title    = "Daily Loss Limit — Prop ($)",
     minval   = -10000.0,
     maxval   = -100.0,
     step     = 100.0,
     tooltip  = "Circuit breaker triggers when daily P&L reaches this level (Prop account). Must be stricter than Live.",
     group    = GRP_RISK)

i_max_daily_trades = input.int(
     defval   = 3,
     title    = "Maximum Daily Trades",
     minval   = 1,
     maxval   = 10,
     tooltip  = "No new entries permitted once this count is reached for the day.",
     group    = GRP_RISK)

i_trailing_dd_limit = input.float(
     defval   = -5000.0,
     title    = "Trailing Drawdown Limit ($)",
     minval   = -50000.0,
     maxval   = -500.0,
     step     = 500.0,
     tooltip  = "All-time trailing drawdown limit. Circuit breaker triggers if equity_peak - current_equity exceeds this.",
     group    = GRP_RISK)

// ============================================================================
// SECTION 3: MODEL CONFIGURATION
// ============================================================================

var string GRP_MODELS = "Execution Model Configuration"

i_enable_a1 = input.bool(
     defval   = true,
     title    = "Enable Model A1 (Depth-Constrained Pullback)",
     tooltip  = "Model A1: PM session EMA21 pullback with ADX filter. Validated PF=1.387.",
     group    = GRP_MODELS)

i_enable_a3 = input.bool(
     defval   = true,
     title    = "Enable Model A3 (Overnight Expansion)",
     tooltip  = "Model A3: Overnight VolComp→Expansion with ADX>=25. Validated PF=1.566.",
     group    = GRP_MODELS)

i_enable_b1 = input.bool(
     defval   = true,
     title    = "Enable Model B1 (Participation-Amplified Momentum)",
     tooltip  = "Model B1: MVC-003 AM session momentum. Validated PF=2.231.",
     group    = GRP_MODELS)

// ============================================================================
// SECTION 4: ATLAS DECISION ENGINE (ADE) CONFIGURATION
// ============================================================================

var string GRP_ADE = "Atlas Decision Engine"

i_edge_score_threshold = input.float(
     defval   = 60.0,
     title    = "Edge Score Threshold (0–100)",
     minval   = 50.0,
     maxval   = 90.0,
     step     = 1.0,
     tooltip  = "Minimum Edge Score required for a model to be selected as Candidate. APS default: 60.",
     group    = GRP_ADE)

// ============================================================================
// SECTION 5: ARI RISK MULTIPLIER CONFIGURATION
// ============================================================================

var string GRP_ARI = "Atlas Risk Intelligence (ARI)"

i_ari_caution_multiplier = input.float(
     defval   = 0.5,
     title    = "ARI Caution Risk Multiplier",
     minval   = 0.25,
     maxval   = 1.0,
     step     = 0.25,
     tooltip  = "Risk multiplier applied when consecutive_losses == 2. APS default: 0.5x.",
     group    = GRP_ARI)

i_ari_compound_multiplier = input.float(
     defval   = 1.1,
     title    = "ARI Compound Risk Multiplier",
     minval   = 1.0,
     maxval   = 2.0,
     step     = 0.1,
     tooltip  = "Risk multiplier applied during winning streaks (consecutive_wins >= 3). APS default: 1.1x.",
     group    = GRP_ARI)

i_ari_pause_bars = input.int(
     defval   = 24,
     title    = "ARI Pause Duration (bars after 3 consecutive losses)",
     minval   = 6,
     maxval   = 96,
     step     = 6,
     tooltip  = "Number of 5-minute bars to pause trading after 3 consecutive losses. 24 bars = ~2 hours.",
     group    = GRP_ARI)

// ============================================================================
// SECTION 6: INSTRUMENT CONFIGURATION
// ============================================================================

var string GRP_INSTRUMENT = "Instrument Configuration"

i_timezone = input.string(
     defval   = "America/New_York",
     title    = "Exchange Timezone",
     tooltip  = "Timezone for session boundary calculations. Must match exchange timezone.",
     group    = GRP_INSTRUMENT)

i_rth_open_hour = input.int(
     defval   = 9,
     title    = "RTH Open Hour (ET)",
     minval   = 0,
     maxval   = 23,
     group    = GRP_INSTRUMENT)

i_rth_open_minute = input.int(
     defval   = 30,
     title    = "RTH Open Minute (ET)",
     minval   = 0,
     maxval   = 59,
     group    = GRP_INSTRUMENT)

i_rth_close_hour = input.int(
     defval   = 16,
     title    = "RTH Close Hour (ET)",
     minval   = 0,
     maxval   = 23,
     group    = GRP_INSTRUMENT)

i_rth_close_minute = input.int(
     defval   = 0,
     title    = "RTH Close Minute (ET)",
     minval   = 0,
     maxval   = 59,
     group    = GRP_INSTRUMENT)

i_overnight_start_hour = input.int(
     defval   = 18,
     title    = "Overnight Session Start Hour (ET)",
     minval   = 0,
     maxval   = 23,
     group    = GRP_INSTRUMENT)

// ============================================================================
// SECTION 7: WEBHOOK CONFIGURATION
// ============================================================================

var string GRP_WEBHOOK = "Webhook Configuration"

i_webhook_ticker = input.string(
     defval   = "MNQ1!",
     title    = "Ticker Symbol for Webhook",
     tooltip  = "Ticker symbol included in JSON payload. Must match TradersPost symbol.",
     group    = GRP_WEBHOOK)

i_webhook_account_id = input.string(
     defval   = "ATLAS_LIVE_01",
     title    = "Account ID for Webhook",
     tooltip  = "Account identifier included in JSON payload for routing.",
     group    = GRP_WEBHOOK)

// ============================================================================
// SECTION 8: DEBUG AND DISPLAY CONFIGURATION
// ============================================================================

var string GRP_DEBUG = "Debug and Display"

i_debug_mode = input.bool(
     defval   = false,
     title    = "Engineering Debug Mode",
     tooltip  = "Enables debug dashboard. NO TRADES ARE PLACED in debug mode. NO ALERTS ARE FIRED.",
     group    = GRP_DEBUG)

i_show_signals = input.bool(
     defval   = true,
     title    = "Show Signal Labels on Chart",
     tooltip  = "Renders entry/exit labels on the chart for visual verification.",
     group    = GRP_DEBUG)

i_show_debug_table = input.bool(
     defval   = false,
     title    = "Show Debug Table",
     tooltip  = "Renders the M-13 debug table. Only active when debug_mode is also true.",
     group    = GRP_DEBUG)

i_log_all_rejections = input.bool(
     defval   = false,
     title    = "Log All ARI/TVL Rejections",
     tooltip  = "Logs every ARI and TVL rejection as a chart label. Useful for system verification.",
     group    = GRP_DEBUG)

// ============================================================================
// CONFIGURATION EXPORT FUNCTION
// Purpose: Provides a single access point for all config values.
// Called by M-14 atlas_core on every bar.
// ============================================================================

// NOTE: In TradingView Pine Script, input.* values are globally accessible
// as script-level variables. This module serves as the documentation and
// grouping layer. Other modules reference these variables by name.
//
// The following export summary is provided for documentation purposes:
//
// ACCOUNT:    i_account_type, i_base_risk, i_max_contracts, i_point_value
// RISK:       i_daily_loss_limit_live, i_daily_loss_limit_prop,
//             i_max_daily_trades, i_trailing_dd_limit
// MODELS:     i_enable_a1, i_enable_a3, i_enable_b1
// ADE:        i_edge_score_threshold
// ARI:        i_ari_caution_multiplier, i_ari_compound_multiplier, i_ari_pause_bars
// INSTRUMENT: i_timezone, i_rth_open_hour, i_rth_open_minute,
//             i_rth_close_hour, i_rth_close_minute, i_overnight_start_hour
// WEBHOOK:    i_webhook_ticker, i_webhook_account_id
// DEBUG:      i_debug_mode, i_show_signals, i_show_debug_table, i_log_all_rejections

// ============================================================================
// VERIFICATION OUTPUT (visible when this indicator is loaded on chart)
// ============================================================================

// Display current configuration summary as a table
var table config_table = table.new(position.top_right, 2, 12,
     bgcolor      = color.new(color.navy, 85),
     border_color = color.new(color.blue, 50),
     border_width = 1)

if barstate.islast
    table.cell(config_table, 0, 0,  "M-00: Atlas Config",   text_color=color.yellow, text_size=size.small)
    table.cell(config_table, 1, 0,  "Value",                 text_color=color.yellow, text_size=size.small)
    table.cell(config_table, 0, 1,  "Account Type",          text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 1,  i_account_type,          text_color=color.aqua,   text_size=size.tiny)
    table.cell(config_table, 0, 2,  "Base Risk ($)",         text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 2,  str.tostring(i_base_risk, "#.00"), text_color=color.aqua, text_size=size.tiny)
    table.cell(config_table, 0, 3,  "Daily Limit (Live)",    text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 3,  str.tostring(i_daily_loss_limit_live, "#.00"), text_color=color.aqua, text_size=size.tiny)
    table.cell(config_table, 0, 4,  "Daily Limit (Prop)",    text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 4,  str.tostring(i_daily_loss_limit_prop, "#.00"), text_color=color.aqua, text_size=size.tiny)
    table.cell(config_table, 0, 5,  "Model A1 Enabled",      text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 5,  i_enable_a1 ? "YES" : "NO", text_color=i_enable_a1 ? color.green : color.red, text_size=size.tiny)
    table.cell(config_table, 0, 6,  "Model A3 Enabled",      text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 6,  i_enable_a3 ? "YES" : "NO", text_color=i_enable_a3 ? color.green : color.red, text_size=size.tiny)
    table.cell(config_table, 0, 7,  "Model B1 Enabled",      text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 7,  i_enable_b1 ? "YES" : "NO", text_color=i_enable_b1 ? color.green : color.red, text_size=size.tiny)
    table.cell(config_table, 0, 8,  "Edge Score Threshold",  text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 8,  str.tostring(i_edge_score_threshold, "#.0"), text_color=color.aqua, text_size=size.tiny)
    table.cell(config_table, 0, 9,  "Debug Mode",            text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 9,  i_debug_mode ? "ACTIVE" : "OFF", text_color=i_debug_mode ? color.orange : color.gray, text_size=size.tiny)
    table.cell(config_table, 0, 10, "Webhook Ticker",        text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 10, i_webhook_ticker,        text_color=color.aqua,   text_size=size.tiny)
    table.cell(config_table, 0, 11, "Point Value ($)",       text_color=color.white,  text_size=size.tiny)
    table.cell(config_table, 1, 11, str.tostring(i_point_value, "#.00"), text_color=color.aqua, text_size=size.tiny)
