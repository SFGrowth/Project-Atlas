// =============================================================================
// ATLAS ARD OBSERVER — M-16
// atlas_ard_observer_m16.pine
// =============================================================================
// Sprint:   095A
// Version:  1.2.0
// Module:   M-16
// Purpose:  ATLAS MEMORY — Emits one BAR_OBSERVATION for every confirmed
//           five-minute MNQ candle. No candle is ever skipped.
//
// CONSTITUTIONAL BASIS:
//   Atlas Constitution v1.0 — Law 5: Every Five-Minute Candle Is a Research Event.
//   Atlas Constitutional Amendment — ATLAS MEMORY:
//     "Every confirmed five-minute candle represents one market observation.
//      Every market observation becomes permanent Atlas memory."
//
// ARCHITECTURAL PRINCIPLE:
//   M-16 is ATLAS MEMORY INFRASTRUCTURE.
//   It never generates execution alerts.
//   It never influences model decisions, ARI, TVL, or the Kernel.
//   It is completely isolated from M-14 (execution) and M-15 (observability).
//   Failure of M-16 must never block or alter the Atlas pipeline.
//
// EVENT CLASS: BAR_OBSERVATION (continuous market-state snapshot)
//   STREAM A: ATLAS MEMORY — every confirmed candle, always emitted, never skipped.
//   STREAM B: ATLAS EVENTS (signals, entries, exits) — handled by M-14/M-15.
//   The two streams are independent.
//
// PAYLOAD DESIGN:
//   Compact flat JSON — all key market-state dimensions in one object.
//   Stays under TradingView's 4000-character alert limit.
//   Idempotency key: symbol_bartime (enforced server-side).
//   Failed delivery returns 200 to Pine — never affects Pine decisions.
//
// ATLAS NEXUS ENDPOINT: POST /api/webhook/atlas-memory/<ATLAS_WEBHOOK_TOKEN>
// AUTHENTICATION: Secret path segment in URL (same token as M-15).
//
// SETUP:
//   1. Add this indicator to the same MNQ 5-minute chart as M-14 and M-15.
//   2. Create a TradingView alert on this indicator:
//      - Condition: "Atlas ARD Observer — M-16" → "Bar Observation Trigger"
//      - Message: {{plot("BAR_OBS_TRIGGER")}} — NOT used; use alert() function
//      - Webhook URL: https://atlasdash-j7nzp34b.manus.space/api/webhook/atlas-memory/<TOKEN>
//      - Alert message: leave blank (alert() function sends the JSON payload)
//   3. Frequency: Once Per Bar Close
//   4. Expiry: Open-ended
//
// DEPENDENCIES:
//   Recomputes all market state variables inline (Pine Script cannot share
//   variables between indicators). Uses identical calculation logic to M-15
//   to ensure consistency.
//
// FAIL-SAFE:
//   All na() guards applied. Serialisation errors produce a minimal error
//   payload. The alert always fires — even on error — to maintain the
//   continuous observation record.
// =============================================================================

//@version=5
indicator("Atlas ARD Observer — M-16", overlay=false, max_labels_count=10, max_lines_count=0)

// ============================================================================
// SECTION 1: CONSTANTS
// ============================================================================
var string SCHEMA_VERSION   = "1.2.0"
var string ATLAS_VERSION    = "Sprint-095A"
var string EVENT_TYPE       = "BAR_OBSERVATION"
var string SYMBOL           = "MNQ1!"
var string TIMEFRAME_STR    = "5"
var string MODULE_VERSION   = "1.2.0"
var int    SPRINT_NUMBER    = 95

// ============================================================================
// SECTION 2: INPUTS
// ============================================================================
var string GRP_ARD  = "ARD Observer Configuration"
var string GRP_SB1  = "SB1 Regime State"
var string GRP_DBG  = "Debug"

i_webhook_secret  = input.string("REPLACE_WITH_ATLAS_WEBHOOK_TOKEN", title="Webhook Token", group=GRP_ARD, tooltip="Must match ATLAS_WEBHOOK_TOKEN. Never share.")
i_enable_webhook  = input.bool(true,  title="Enable Webhook Transmission", group=GRP_ARD)
i_show_table      = input.bool(true,  title="Show Status Table", group=GRP_DBG)
i_show_heartbeat  = input.bool(true,  title="Show Heartbeat Label", group=GRP_DBG)

// SB1 RAS (manually updated from Atlas Nexus until Pine-side computation is available)
i_sb1_ras         = input.float(0.0,  title="SB1 RAS (0–100)", minval=0, maxval=100, step=0.1, group=GRP_SB1)
i_sb1_activated   = input.bool(false, title="SB1 RAS Activated (≥45)", group=GRP_SB1)

// ============================================================================
// SECTION 3: UTILITY FUNCTIONS
// ============================================================================

// Float to string with format
f_fts(v, fmt) =>
    na(v) ? "null" : str.tostring(v, fmt)

// Bool to string
f_bts(b) =>
    b ? "true" : "false"

// String to JSON string (quoted, null-safe)
f_str(s) =>
    na(s) or str.length(s) == 0 ? "null" : "\"" + s + "\""

// Int to string
f_its(v) =>
    str.tostring(v)

// Generate event_id: M16_symbol_barindex_time
f_event_id(bi, t) =>
    "M16_" + SYMBOL + "_" + str.tostring(bi) + "_" + str.tostring(t)

// Generate idempotency_key: symbol_bartime_utc
f_idem_key(bi, t) =>
    SYMBOL + "_" + str.tostring(t)

// Generate memory_id: MEM_symbol_time
f_memory_id(t) =>
    "MEM_" + SYMBOL + "_" + str.tostring(t)

// ============================================================================
// SECTION 4: MARKET STATE CALCULATIONS
// (Identical to M-15 to ensure consistency)
// ============================================================================

// ── EMAs ──────────────────────────────────────────────────────────────────────
ema9_val   = ta.ema(close, 9)
ema21_val  = ta.ema(close, 21)
ema50_val  = ta.ema(close, 50)
ema200_val = ta.ema(close, 200)

// EMA slopes (change over 3 bars, normalised by ATR)
atr14_val  = ta.atr(14)
atr5_val   = ta.atr(5)
safe_atr   = na(atr14_val) or atr14_val <= 0 ? 1.0 : atr14_val

ema9_slope  = na(ema9_val[3])  ? 0.0 : (ema9_val  - ema9_val[3])  / safe_atr
ema21_slope = na(ema21_val[3]) ? 0.0 : (ema21_val - ema21_val[3]) / safe_atr
ema50_slope = na(ema50_val[3]) ? 0.0 : (ema50_val - ema50_val[3]) / safe_atr

// EMA alignment
ema_bull_val = not na(ema9_val) and not na(ema21_val) and not na(ema50_val) and ema9_val > ema21_val and ema21_val > ema50_val
ema_bear_val = not na(ema9_val) and not na(ema21_val) and not na(ema50_val) and ema9_val < ema21_val and ema21_val < ema50_val
ema_struct   = ema_bull_val ? "BULL" : ema_bear_val ? "BEAR" : "MIXED"
trend_dir    = ema_bull_val ? "LONG" : ema_bear_val ? "SHORT" : "FLAT"

// ── ADX ───────────────────────────────────────────────────────────────────────
[diplus, diminus, adx14_val] = ta.dmi(14, 14)
adx_trending_val = not na(adx14_val) and adx14_val >= 25.0

// ── CHOP Index ────────────────────────────────────────────────────────────────
chop_val = 100.0 * math.log10(math.sum(ta.atr(1), 14) / (ta.highest(high, 14) - ta.lowest(low, 14))) / math.log10(14)

// ── RSI ───────────────────────────────────────────────────────────────────────
rsi_val = ta.rsi(close, 14)

// ── VWAP ─────────────────────────────────────────────────────────────────────
vwap_val = ta.vwap(close)

// ── Volatility State ─────────────────────────────────────────────────────────
atr_mean20  = ta.sma(atr14_val, 20)
volcomp_val = na(atr_mean20) or atr_mean20 <= 0 ? 1.0 : atr14_val / atr_mean20
is_comp_val = volcomp_val < 0.85
is_exp_val  = volcomp_val > 1.20
vol_state_val = is_comp_val ? "COMPRESSED" : is_exp_val ? "EXPANDING" : "NORMAL"

// ── ATR Percentile (rolling 20-bar rank)
atr_pct_rank = ta.percentrank(atr14_val, 20)

// ── Distance from VWAP
dist_vwap = na(vwap_val) ? 0.0 : close - vwap_val

// ── Compression/Expansion ────────────────────────────────────────────────────
comp_state_val = is_comp_val ? "COMPRESSED" : is_exp_val ? "EXPANDING" : "NEUTRAL"

// ── Session Classification ────────────────────────────────────────────────────
h_et = hour(time, "America/New_York")
m_et = minute(time, "America/New_York")
dow_val = dayofweek(time, "America/New_York")

is_rth_val = h_et >= 9 and (h_et < 16 or (h_et == 16 and m_et == 0))
is_am_val  = h_et >= 9 and h_et < 12
is_pm_val  = h_et >= 12 and h_et < 16
is_ov_val  = not is_rth_val

session_val = is_am_val ? "AM" : is_pm_val ? "PM" : is_ov_val ? "OV" : "MID"

dow_str = dow_val == dayofweek.monday ? "MON" :
          dow_val == dayofweek.tuesday ? "TUE" :
          dow_val == dayofweek.wednesday ? "WED" :
          dow_val == dayofweek.thursday ? "THU" :
          dow_val == dayofweek.friday ? "FRI" :
          dow_val == dayofweek.saturday ? "SAT" : "SUN"

// ── Regime Classification ─────────────────────────────────────────────────────
regime_val = adx_trending_val and ema_bull_val ? "TRENDING_BULL" :
             adx_trending_val and ema_bear_val ? "TRENDING_BEAR" :
             is_comp_val ? "COMPRESSED" :
             not adx_trending_val ? "CHOPPY" : "TRANSITIONAL"

// ── Previous Day Structure ────────────────────────────────────────────────────
// Using daily timeframe request for prev day OHLC
pd_high  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
pd_low   = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)
pd_close = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)
pd_open  = request.security(syminfo.tickerid, "D", open[1],  lookahead=barmerge.lookahead_on)

safe_pd_high  = na(pd_high)  ? close : pd_high
safe_pd_low   = na(pd_low)   ? close : pd_low
safe_pd_close = na(pd_close) ? close : pd_close
pd_range      = safe_pd_high - safe_pd_low
pd_range_atr  = safe_atr > 0 ? pd_range / safe_atr : 0.0

price_vs_pd = close > safe_pd_high ? "ABOVE_PDH" :
              close < safe_pd_low  ? "BELOW_PDL" :
              close > safe_pd_close ? "ABOVE_PDC" : "BELOW_PDC"

// ── Overnight Gap ─────────────────────────────────────────────────────────────
ov_gap = safe_pd_close > 0 ? (open - safe_pd_close) / safe_atr : 0.0

// ── Model Eligibility (simplified — full logic in M-14/M-15) ─────────────────
// These are approximate eligibility flags for ARD context.
// Full model evaluation occurs in M-14.
a1_eligible = adx_trending_val and is_rth_val
a3_eligible = adx_trending_val and is_rth_val
b1_eligible = is_rth_val and not is_comp_val
sb1_eligible = is_rth_val and adx_trending_val and (ema_bull_val or ema_bear_val)
// ORB-1: RTH + (ADX trending OR ATR expanding above 20-bar mean)
// Sprint 095A recalibration: volcomp > 1.00 captures TREND and VOLATILE days
orb1_eligible = is_rth_val and (adx_trending_val or volcomp_val > 1.00)

// ── Active Models string
active_models_str = (a1_eligible ? "A1" : "") + (a3_eligible ? (a1_eligible ? ",A3" : "A3") : "") + (b1_eligible ? ((a1_eligible or a3_eligible) ? ",B1" : "B1") : "") + (sb1_eligible ? ((a1_eligible or a3_eligible or b1_eligible) ? ",SB1" : "SB1") : "") + (orb1_eligible ? ((a1_eligible or a3_eligible or b1_eligible or sb1_eligible) ? ",ORB1" : "ORB1") : "")
active_models_display = str.length(active_models_str) > 0 ? active_models_str : "NONE"

// ============================================================================
// SECTION 5: COUNTERS
// ============================================================================
var int v_obs_count   = 0
var int v_error_count = 0

// ============================================================================
// SECTION 6: PAYLOAD CONSTRUCTION AND TRANSMISSION
// ============================================================================
if barstate.isconfirmed
    v_obs_count := v_obs_count + 1

    // Generate keys
    string mem_id   = f_memory_id(time)
    string evt_id   = f_event_id(bar_index, time)
    string idem_key = f_idem_key(bar_index, time)

    // Timestamp ET
    string ts_et = str.tostring(year(time, "America/New_York")) + "-" +
                   str.tostring(month(time, "America/New_York"), "00") + "-" +
                   str.tostring(dayofmonth(time, "America/New_York"), "00") + "T" +
                   str.tostring(h_et, "00") + ":" +
                   str.tostring(m_et, "00") + ":00"

    // ── Build Atlas Memory BAR_OBSERVATION JSON — Sprint 089A ────────────────────────────────────
    // Design: flat JSON, all fields at top level, stays under 4000 chars.
    // Field naming: snake_case, consistent with Atlas Nexus schema.

    string j = "{"

    // ── Identity ──────────────────────────────────────────────────────────────
    j := j + "\"event_type\":\"" + EVENT_TYPE + "\","
    j := j + "\"schema_version\":\"" + SCHEMA_VERSION + "\","
    j := j + "\"atlas_version\":\"" + ATLAS_VERSION + "\","
    j := j + "\"memory_id\":\"" + mem_id + "\","
    j := j + "\"event_id\":\"" + evt_id + "\","
    j := j + "\"idempotency_key\":\"" + idem_key + "\","
    j := j + "\"symbol\":\"" + SYMBOL + "\","
    j := j + "\"timeframe\":\"" + TIMEFRAME_STR + "\","
    j := j + "\"bar_index\":" + str.tostring(bar_index) + ","
    j := j + "\"pipeline_run_id\":\"" + idem_key + "\","

    // ── Timestamp ─────────────────────────────────────────────────────────────
    j := j + "\"bar_time\":" + f_its(time) + ","
    j := j + "\"bar_time_et\":\"" + ts_et + "\","
    j := j + "\"session\":\"" + session_val + "\","
    j := j + "\"day_of_week\":\"" + dow_str + "\","
    j := j + "\"hour_et\":" + str.tostring(h_et) + ","
    j := j + "\"is_rth\":" + f_bts(is_rth_val) + ","

    // ── OHLCV ─────────────────────────────────────────────────────────────────
    j := j + "\"open\":" + f_fts(open, "#.00") + ","
    j := j + "\"high\":" + f_fts(high, "#.00") + ","
    j := j + "\"low\":" + f_fts(low, "#.00") + ","
    j := j + "\"close\":" + f_fts(close, "#.00") + ","
    j := j + "\"volume\":" + f_fts(volume, "#") + ","

    // ── Core Indicators ───────────────────────────────────────────────────────
    j := j + "\"atr\":" + f_fts(atr14_val, "#.####") + ","
    j := j + "\"atr5\":" + f_fts(atr5_val, "#.####") + ","
    j := j + "\"atr_expansion\":" + f_fts(volcomp_val, "#.####") + ","
    j := j + "\"atr_percentile\":" + f_fts(atr_pct_rank, "#.##") + ","
    j := j + "\"adx\":" + f_fts(adx14_val, "#.##") + ","
    j := j + "\"adx_trending\":" + f_bts(adx_trending_val) + ","
    j := j + "\"chop\":" + f_fts(chop_val, "#.##") + ","
    j := j + "\"rsi\":" + f_fts(rsi_val, "#.##") + ","
    j := j + "\"vwap\":" + f_fts(vwap_val, "#.00") + ","
    j := j + "\"dist_vwap\":" + f_fts(dist_vwap, "#.00") + ","

    // ── EMAs ──────────────────────────────────────────────────────────────────
    j := j + "\"ema9\":" + f_fts(ema9_val, "#.00") + ","
    j := j + "\"ema21\":" + f_fts(ema21_val, "#.00") + ","
    j := j + "\"ema50\":" + f_fts(ema50_val, "#.00") + ","
    j := j + "\"ema200\":" + f_fts(ema200_val, "#.00") + ","
    j := j + "\"ema9_slope\":" + f_fts(ema9_slope, "#.######") + ","
    j := j + "\"ema21_slope\":" + f_fts(ema21_slope, "#.######") + ","
    j := j + "\"ema50_slope\":" + f_fts(ema50_slope, "#.######") + ","
    j := j + "\"ema_alignment\":\"" + ema_struct + "\","
    j := j + "\"trend_direction\":\"" + trend_dir + "\","

    // ── Regime ────────────────────────────────────────────────────────────────
    j := j + "\"volatility_state\":\"" + vol_state_val + "\","
    j := j + "\"compression_state\":\"" + comp_state_val + "\","
    j := j + "\"regime_classification\":\"" + regime_val + ","

    // ── Previous Day Structure ────────────────────────────────────────────────
    j := j + "\"prev_day_high\":" + f_fts(safe_pd_high, "#.00") + ","
    j := j + "\"prev_day_low\":" + f_fts(safe_pd_low, "#.00") + ","
    j := j + "\"prev_day_close\":" + f_fts(safe_pd_close, "#.00") + ","
    j := j + "\"prev_day_range\":" + f_fts(pd_range, "#.00") + ","
    j := j + "\"prev_day_range_atr\":" + f_fts(pd_range_atr, "#.####") + ","
    j := j + "\"overnight_gap\":" + f_fts(ov_gap, "#.####") + ","
    j := j + "\"price_vs_prev_day\":\"" + price_vs_pd + "\","

    // ── Model Eligibility ─────────────────────────────────────────────────────
    j := j + "\"a1_eligible\":" + f_bts(a1_eligible) + ","
    j := j + "\"a3_eligible\":" + f_bts(a3_eligible) + ","
    j := j + "\"b1_eligible\":" + f_bts(b1_eligible) + ","
        j := j + "\"sb1_eligible\":" + f_bts(sb1_eligible) + ","
    j := j + "\"orb1_eligible\":" + f_bts(orb1_eligible) + ","
    j := j + "\"active_models\":\"" + active_models_display + "\","
    // ── SB1 RAS (from inputs — updated from Atlas Nexus) ──────────────────────
    j := j + "\"sb1_ras\":" + f_fts(i_sb1_ras, "#.##") + ","
    j := j + "\"sb1_ras_activated\":" + f_bts(i_sb1_activated) + ","

    // ── Pipeline Health ───────────────────────────────────────────────────────
    j := j + "\"pipeline_health\":\"" + (na(ema9_val) ? "DEGRADED" : "OK") + "\","
    j := j + "\"obs_count\":" + str.tostring(v_obs_count) + ","
    j := j + "\"error_count\":" + str.tostring(v_error_count) + ","
    j := j + "\"module_version\":\"" + MODULE_VERSION + "\","
    j := j + "\"sprint\":" + str.tostring(SPRINT_NUMBER)
    j := j + "}"

    // ── Transmit — ATLAS MEMORY: unconditional, every confirmed candle ─────────
    if i_enable_webhook
        alert(j, alert.freq_once_per_bar_close)

// ============================================================================
// SECTION 7: STATUS TABLE
// ============================================================================
var table t_status = na
if i_show_table and barstate.islast
    if na(t_status)
        t_status := table.new(position.top_right, 2, 15, bgcolor=color.new(color.black, 10), border_width=1, border_color=color.new(color.gray, 60), frame_width=1, frame_color=color.new(color.gray, 40))

    f_row(idx, k, v, vc) =>
        table.cell(t_status, 0, idx, k, text_color=color.new(color.gray, 20), text_size=size.small, bgcolor=color.new(color.black, 20))
        table.cell(t_status, 1, idx, v, text_color=vc, text_size=size.small, bgcolor=color.new(color.black, 10))

    f_row(0,  "ATLAS MEMORY M-16",  "v" + MODULE_VERSION + " [095A]",                                   color.new(color.cyan, 0))
    f_row(1,  "Webhook",            i_enable_webhook ? "ENABLED" : "DISABLED",              i_enable_webhook ? color.new(color.green, 0) : color.new(color.yellow, 0))
    f_row(2,  "Observations",       str.tostring(v_obs_count),                              color.new(color.white, 0))
    f_row(3,  "Errors",             str.tostring(v_error_count),                            v_error_count > 0 ? color.new(color.red, 0) : color.new(color.green, 0))
    f_row(4,  "Session",            session_val,                                            color.new(color.yellow, 0))
    f_row(5,  "Regime",             regime_val,                                             adx_trending_val ? color.new(color.green, 0) : color.new(color.gray, 0))
    f_row(6,  "ADX",                str.tostring(adx14_val, "#.#"),                         adx_trending_val ? color.new(color.green, 0) : color.new(color.gray, 0))
    f_row(7,  "CHOP",               str.tostring(chop_val, "#.#"),                          chop_val < 55 ? color.new(color.green, 0) : color.new(color.red, 0))
    f_row(8,  "EMA Align",          ema_struct,                                             ema_bull_val ? color.new(color.green, 0) : ema_bear_val ? color.new(color.red, 0) : color.new(color.yellow, 0))
    f_row(9,  "ATR Expansion",      str.tostring(volcomp_val, "#.###"),                     is_exp_val ? color.new(color.orange, 0) : is_comp_val ? color.new(color.blue, 0) : color.new(color.white, 0))
    f_row(10, "Active Models",      active_models_display,                                      color.new(color.cyan, 0))
    f_row(11, "ORB-1",              orb1_eligible ? "ELIGIBLE" : "NOT ELIGIBLE",               orb1_eligible ? color.new(color.green, 0) : color.new(color.gray, 0))
    f_row(12, "SB1 RAS",            str.tostring(i_sb1_ras, "#.#") + (i_sb1_activated ? " ✓ ACTIVE" : " ✗ SUPPRESSED"), i_sb1_activated ? color.new(color.green, 0) : color.new(color.red, 0))
    f_row(13, "Confirmed",          barstate.isconfirmed ? "YES" : "NO",                   barstate.isconfirmed ? color.new(color.green, 0) : color.new(color.yellow, 0))

// ============================================================================
// SECTION 8: HEARTBEAT LABEL
// ============================================================================
if i_show_heartbeat and barstate.islast
    label.new(bar_index, high + atr14_val * 0.5,
              "ATLAS MEMORY M-16 | " + str.tostring(v_obs_count) + " obs | " + regime_val + " | " + (i_enable_webhook ? "LIVE" : "PREVIEW"),
              style=label.style_label_down,
              color=color.new(color.purple, 20),
              textcolor=color.white,
              size=size.small)

// ============================================================================
// SECTION 9: PLOTS (for alert trigger and chart legend)
// ============================================================================
// BAR_OBS_TRIGGER: fires on every confirmed bar — used to verify alert is firing
plot(barstate.isconfirmed ? 1 : 0, title="BAR_OBS_TRIGGER", color=color.new(color.purple, 80), display=display.none)
plot(v_obs_count,   title="Observation Count", color=color.new(color.cyan, 80),   display=display.none)
plot(v_error_count, title="Error Count",       color=color.new(color.red, 80),    display=display.none)
plot(adx14_val,     title="ADX14",             color=color.new(color.yellow, 80), display=display.pane)
plot(chop_val,      title="CHOP14",            color=color.new(color.orange, 80), display=display.pane)
hline(25,  "ADX Trend Threshold", color=color.new(color.green, 60),  linestyle=hline.style_dashed)
hline(55,  "CHOP Choppy",         color=color.new(color.red, 60),    linestyle=hline.style_dashed)
hline(38.2,"CHOP Trending",       color=color.new(color.green, 60),  linestyle=hline.style_dotted)
