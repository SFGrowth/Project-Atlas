# ─── Connections: Market Principles → Guardian Rules ──────────────────────────
mp_layer.mp001 -> guardian_layer.creg001: "Regime filter\nrequired"
mp_layer.mp001 -> guardian_layer.ari_ruleD: "Scale up in\ncompatible regime"
mp_layer.mp002 -> guardian_layer.ari_ruleD: "ADX threshold\nscaling"
mp_layer.mp003 -> guardian_layer.session_filter: "Session\nboundaries"
mp_layer.mp004 -> guardian_layer.creg001: "VolComp\ndetection"
mp_layer.mp008 -> guardian_layer.ari_ruleA: "Structural edge\nrequired"

# ─── Connections: Strategy Family → Guardian Rules ────────────────────────────
sf_layer.mp005 -> guardian_layer.ari_ruleC: "Streak = regime\ntransition → pause"
sf_layer.mp006 -> guardian_layer.session_filter: "Entry requires\nanchor validation"

# ─── Connections: Guardian Rules → Execution Components ──────────────────────
guardian_layer.creg001 -> exec_layer.volcomp_signal: "Activates"
guardian_layer.ari_ruleD -> exec_layer.adx_filter: "Scales risk\nby ADX"
guardian_layer.session_filter -> exec_layer.ema_stack: "Restricts\nto session"
guardian_layer.ari_ruleC -> exec_layer.flag_structure: "Pauses after\n2+ losses"

# ─── Connections: Execution Components → Models ───────────────────────────────
exec_layer.volcomp_signal -> model_layer.a1: "VolComp\nprerequisite"
exec_layer.ema_stack -> model_layer.a1: "Trend\nalignment"
exec_layer.adx_filter -> model_layer.a1: "ADX < 30\nfilter"
exec_layer.flag_structure -> model_layer.a2: "Flag\ndetection"
exec_layer.adx_filter -> model_layer.a2: "ADX > 45\nfilter"
exec_layer.overnight_comp -> model_layer.a3: "Compression\ndetection"
exec_layer.adx_filter -> model_layer.a3: "ADX ≥ 25\nfilter"

# ─── Connections: Models → ATS ────────────────────────────────────────────────
model_layer.a1 -> ats: "Low-ADX\nedge"
model_layer.a2 -> ats: "High-ADX\nedge"
model_layer.a3 -> ats: "Overnight\nedge"
