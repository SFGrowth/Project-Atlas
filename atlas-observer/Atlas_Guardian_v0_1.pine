// ═══════════════════════════════════════════════════════════════════════
// Atlas Guardian Decision Engine v0.1
// Sprint 020 — Validated 2026-07-07
//
// Guardian consumes the outputs of the Market Regime Engine and other
// modules to output one of four decisions:
//   PASS, REDUCE RISK, PAPER ONLY, BLOCK
//
// Guardian's responsibility is to maximise survival, not profit.
// ═══════════════════════════════════════════════════════════════════════

//@version=6
indicator("Atlas Guardian Decision Engine v0.1", overlay=true, group="Atlas OS")

import ta

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
grp_regime = "Regime Inputs (v1.0 Frozen)"
fastAtrLen      = input.int(5, "Fast ATR Length", group=grp_regime)
slowAtrLen      = input.int(20, "Slow ATR Length", group=grp_regime)
compressThresh  = input.float(0.7, "Compression Threshold", group=grp_regime)
expandThresh    = input.float(1.1, "Expansion Threshold", group=grp_regime)
vwapThresh      = input.float(1.5, "VWAP Dev Threshold (ATR)", group=grp_regime)

grp_guardian = "Guardian Risk Settings"
rthStartHour    = input.int(9, "RTH Start Hour (ET)", group=grp_guardian)
rthStartMin     = input.int(30, "RTH Start Minute", group=grp_guardian)
rthEndHour      = input.int(16, "RTH End Hour (ET)", group=grp_guardian)
rthEndMin       = input.int(0, "RTH End Minute", group=grp_guardian)
drawdownMult    = input.float(3.0, "High Risk Drawdown Multiplier", group=grp_guardian)

// ─────────────────────────────────────────────────────────────────────────────
// REGIME ENGINE v1.0 (FROZEN LOGIC)
// ─────────────────────────────────────────────────────────────────────────────
fastAtr  = ta.atr(fastAtrLen)
slowAtr  = ta.atr(slowAtrLen)
atrRatio = slowAtr > 0 ? fastAtr / slowAtr : 1.0

var float cumVolPrice = 0.0
var float cumVol      = 0.0
if session.is_first_bar
    cumVolPrice := 0.0
    cumVol      := 0.0
cumVolPrice += hlc3 * volume
cumVol      += volume
vwapValue = cumVol > 0 ? cumVolPrice / cumVol : close
vwapDev   = ta.atr(14) > 0 ? math.abs(close - vwapValue) / ta.atr(14) : 0.0

isCompressed   = atrRatio <= compressThresh
isExpanded     = atrRatio >= expandThresh
isGoodLocation = vwapDev  <= vwapThresh

tradeabilityScore = 0
if isCompressed
    tradeabilityScore += 50
else if isExpanded
    tradeabilityScore += 25
if isGoodLocation
    tradeabilityScore += 25

// ─────────────────────────────────────────────────────────────────────────────
// GUARDIAN DECISION LOGIC
// ─────────────────────────────────────────────────────────────────────────────
// Session Context
timeDecimal = hour(time, "America/New_York") + minute(time, "America/New_York") / 60.0
rthStart    = rthStartHour + rthStartMin / 60.0
rthEnd      = rthEndHour + rthEndMin / 60.0

isRTH           = timeDecimal >= rthStart and timeDecimal < rthEnd
isOpeningAuction = timeDecimal >= 9.5 and timeDecimal < 10.0
isLunch         = timeDecimal >= 12.0 and timeDecimal < 13.5

// High Risk State (Drawdown proxy: fast downside momentum)
recentLossProxy = close - close[5]
isHighRiskState = recentLossProxy < -(slowAtr * drawdownMult)

// Guardian Decision
// 3 = PASS, 2 = REDUCE RISK, 1 = PAPER ONLY, 0 = BLOCK
int guardianDecision = 3
string guardianReason = "Clear"
color guardianColor = color.green

if not isRTH
    guardianDecision := 0
    guardianReason := "Outside RTH"
    guardianColor := color.gray
else if tradeabilityScore == 0
    guardianDecision := 0
    guardianReason := "Zero Tradeability"
    guardianColor := color.red
else if isHighRiskState
    guardianDecision := 1
    guardianReason := "High Risk State"
    guardianColor := color.orange
else if isOpeningAuction or isLunch
    guardianDecision := 2
    guardianReason := "Session Context"
    guardianColor := color.yellow
else if tradeabilityScore == 25
    guardianDecision := 2
    guardianReason := "Low Tradeability"
    guardianColor := color.yellow

string decisionText = "PASS"
if guardianDecision == 0
    decisionText := "BLOCK"
else if guardianDecision == 1
    decisionText := "PAPER ONLY"
else if guardianDecision == 2
    decisionText := "REDUCE RISK"

// ─────────────────────────────────────────────────────────────────────────────
// VISUALISATION
// ─────────────────────────────────────────────────────────────────────────────
// Background color based on Guardian Decision
bgcolor(guardianDecision == 0 ? color.new(color.red, 95) :
        guardianDecision == 1 ? color.new(color.orange, 90) :
        guardianDecision == 2 ? color.new(color.yellow, 90) :
        guardianDecision == 3 ? color.new(color.green, 95) : na,
        title = "Guardian Background")

var table dashboard = table.new(position.bottom_right, 2, 5,
     bgcolor      = color.new(color.black, 80),
     border_width = 1,
     border_color = color.gray)

if barstate.islast
    table.cell(dashboard, 0, 0, "Atlas Guardian",
         text_color = color.white, text_size = size.small,
         bgcolor    = color.new(color.black, 0))
    table.cell(dashboard, 1, 0, "v0.1",
         text_color = color.gray, text_size = size.tiny,
         bgcolor    = color.new(color.black, 0))

    table.cell(dashboard, 0, 1, "Decision",
         text_color = color.white, text_size = size.normal)
    table.cell(dashboard, 1, 1, decisionText,
         text_color = guardianColor, text_size = size.normal)

    table.cell(dashboard, 0, 2, "Reason",
         text_color = color.white, text_size = size.small)
    table.cell(dashboard, 1, 2, guardianReason,
         text_color = color.white, text_size = size.small)

    table.cell(dashboard, 0, 3, "Tradeability",
         text_color = color.white, text_size = size.small)
    table.cell(dashboard, 1, 3, str.tostring(tradeabilityScore),
         text_color = tradeabilityScore >= 75 ? color.green : color.red, text_size = size.small)

    table.cell(dashboard, 0, 4, "Risk State",
         text_color = color.white, text_size = size.small)
    table.cell(dashboard, 1, 4, isHighRiskState ? "ELEVATED" : "NORMAL",
         text_color = isHighRiskState ? color.orange : color.green, text_size = size.small)
