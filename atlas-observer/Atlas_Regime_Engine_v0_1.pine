//@version=6
indicator("Atlas Market Regime Engine v0.1", overlay=true, group="Atlas OS")

// ─────────────────────────────────────────────────────────────────────────────
// ATLAS MARKET REGIME ENGINE — SPRINT 019
// 
// Validated Hypotheses:
// H2: ATR Expansion predicts continuation
// H6: Volatility Compression predicts high-expectancy breakouts
// H7: VWAP Deviation filters poor location
// ─────────────────────────────────────────────────────────────────────────────

import ta

// --- Inputs ---
grp_regime = "Regime Parameters"
fastAtrLen = input.int(5, "Fast ATR Length", group=grp_regime)
slowAtrLen = input.int(20, "Slow ATR Length", group=grp_regime)
compressThresh = input.float(0.7, "Compression Threshold", group=grp_regime)
expandThresh = input.float(1.1, "Expansion Threshold", group=grp_regime)
vwapThresh = input.float(1.5, "VWAP Dev Threshold (ATR)", group=grp_regime)

// --- Computations ---
fastAtr = ta.atr(fastAtrLen)
slowAtr = ta.atr(slowAtrLen)
atrRatio = slowAtr > 0 ? fastAtr / slowAtr : 1.0

// VWAP Deviation
var float cumVolPrice = 0.0
var float cumVol = 0.0
if session.is_first_bar
    cumVolPrice := 0.0
    cumVol := 0.0
cumVolPrice += hlc3 * volume
cumVol += volume
vwapValue = cumVol > 0 ? cumVolPrice / cumVol : close
vwapDev = ta.atr(14) > 0 ? math.abs(close - vwapValue) / ta.atr(14) : 0.0

// --- Classifications ---
isCompressed = atrRatio <= compressThresh
isExpanded = atrRatio >= expandThresh
isGoodLocation = vwapDev <= vwapThresh

// Tradeability Score (0-100)
// Base 0, +50 for compression, +25 for expansion, +25 for good location
tradeabilityScore = 0
if isCompressed
    tradeabilityScore += 50
else if isExpanded
    tradeabilityScore += 25
if isGoodLocation
    tradeabilityScore += 25

// Regime Label
string regimeName = "Neutral"
color regimeColor = color.gray
if isCompressed
    regimeName := "Compression"
    regimeColor := color.new(color.blue, 0)
else if isExpanded
    regimeName := "Expansion"
    regimeColor := color.new(color.orange, 0)

// --- Visualisation ---
// Background color based on Tradeability Score
bgcolor(tradeabilityScore >= 75 ? color.new(color.green, 90) : tradeabilityScore <= 25 ? color.new(color.red, 90) : na, title="Tradeability Background")

// Dashboard
var table dashboard = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)
if barstate.islast
    table.cell(dashboard, 0, 0, "Atlas Regime Engine", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 0))
    table.cell(dashboard, 1, 0, "v0.1", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.black, 0))
    
    table.cell(dashboard, 0, 1, "Regime State", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 1, regimeName, text_color=regimeColor, text_size=size.small)
    
    table.cell(dashboard, 0, 2, "ATR Ratio", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 2, str.tostring(atrRatio, "#.##"), text_color=color.white, text_size=size.small)
    
    table.cell(dashboard, 0, 3, "Tradeability", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 3, str.tostring(tradeabilityScore), text_color=tradeabilityScore >= 75 ? color.green : color.red, text_size=size.small)
