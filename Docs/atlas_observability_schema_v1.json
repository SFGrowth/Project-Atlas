{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "atlas_observability_schema_v1",
  "title": "Atlas Observability Payload",
  "description": "Immutable per-bar observability record generated by M-15 atlas_observability_webhook.pine and transmitted to Atlas Nexus",
  "type": "object",
  "required": [
    "schema_version",
    "payload_type",
    "idempotency_key",
    "metadata",
    "pipeline_health",
    "market_state",
    "model_evaluations",
    "ade_decision",
    "ari_decision",
    "tvl_decision",
    "position_state",
    "reasoning"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Stable schema version — increment on breaking changes"
    },
    "payload_type": {
      "type": "string",
      "const": "OBSERVABILITY",
      "description": "Distinguishes observability payloads from future execution payloads"
    },
    "idempotency_key": {
      "type": "string",
      "description": "Unique key: chart_id + bar_index + timestamp_utc. Prevents duplicate inserts."
    },
    "metadata": {
      "type": "object",
      "required": ["event_id", "timestamp_utc", "bar_index", "chart_id", "ticker", "timeframe", "aps_version", "pine_version", "sprint_number"],
      "properties": {
        "event_id":          { "type": "string",  "description": "UUID-style unique event identifier" },
        "timestamp_utc":     { "type": "integer", "description": "Unix timestamp (ms) of bar close in UTC" },
        "timestamp_et":      { "type": "string",  "description": "Human-readable ET timestamp: YYYY-MM-DD HH:mm" },
        "bar_index":         { "type": "integer", "description": "TradingView bar_index value" },
        "chart_id":          { "type": "string",  "const": "cDPu6HGG" },
        "ticker":            { "type": "string",  "description": "e.g. MNQ1!" },
        "timeframe":         { "type": "string",  "description": "e.g. 5" },
        "aps_version":       { "type": "string",  "description": "Atlas Pipeline System version e.g. 0.12.0" },
        "pine_version":      { "type": "string",  "description": "Pine Script version e.g. 5" },
        "production_version":{ "type": ["string","null"] },
        "sprint_number":     { "type": "integer", "description": "Current sprint number e.g. 74" },
        "git_commit":        { "type": ["string","null"], "description": "Short git commit hash if available" },
        "build_date":        { "type": ["string","null"] }
      }
    },
    "pipeline_health": {
      "type": "object",
      "required": ["pipeline_ok", "heartbeat", "pipeline_run_count"],
      "properties": {
        "pipeline_ok":            { "type": "boolean" },
        "failed_stage":           { "type": ["string","null"] },
        "failure_reason":         { "type": ["string","null"] },
        "warning_count":          { "type": "integer", "minimum": 0 },
        "error_count":            { "type": "integer", "minimum": 0 },
        "heartbeat":              { "type": "integer", "description": "Monotonically increasing heartbeat count" },
        "pipeline_run_count":     { "type": "integer" },
        "last_successful_stage":  { "type": ["string","null"] },
        "stage_config_ok":        { "type": "boolean" },
        "stage_state_ok":         { "type": "boolean" },
        "stage_mse_ok":           { "type": "boolean" },
        "stage_models_ok":        { "type": "boolean" },
        "stage_ade_ok":           { "type": "boolean" },
        "stage_ari_ok":           { "type": "boolean" },
        "stage_tvl_ok":           { "type": "boolean" },
        "stage_exec_ok":          { "type": "boolean" }
      }
    },
    "market_state": {
      "type": "object",
      "properties": {
        "session":              { "type": "string" },
        "timestamp_et":        { "type": "string" },
        "hour_et":             { "type": "integer" },
        "minute_et":           { "type": "integer" },
        "day_of_week":         { "type": "integer" },
        "is_rth":              { "type": "boolean" },
        "is_am_session":       { "type": "boolean" },
        "is_pm_session":       { "type": "boolean" },
        "is_overnight":        { "type": "boolean" },
        "bar_close":           { "type": ["number","null"] },
        "bar_high":            { "type": ["number","null"] },
        "bar_low":             { "type": ["number","null"] },
        "bar_open":            { "type": ["number","null"] },
        "bar_volume":          { "type": ["number","null"] },
        "ema9":                { "type": ["number","null"] },
        "ema21":               { "type": ["number","null"] },
        "ema50":               { "type": ["number","null"] },
        "ema_structure":       { "type": "string", "enum": ["BULL","BEAR","MIXED"] },
        "ema_bull":            { "type": "boolean" },
        "ema_bear":            { "type": "boolean" },
        "atr14":               { "type": ["number","null"] },
        "atr5":                { "type": ["number","null"] },
        "adx14":               { "type": ["number","null"] },
        "adx_trending":        { "type": "boolean" },
        "volatility_state":    { "type": "string" },
        "volcomp_ratio":       { "type": ["number","null"] },
        "is_compressed":       { "type": "boolean" },
        "is_expanding":        { "type": "boolean" },
        "ov_open":             { "type": ["number","null"] },
        "ov_high":             { "type": ["number","null"] },
        "ov_low":              { "type": ["number","null"] },
        "ov_close":            { "type": ["number","null"] },
        "ov_range_pts":        { "type": ["number","null"] },
        "ov_range_vs_atr14":   { "type": ["number","null"] },
        "ov_direction":        { "type": "integer", "enum": [-1, 0, 1] },
        "rel_vol_20":          { "type": ["number","null"] },
        "rel_txn":             { "type": ["number","null"] },
        "participation_surge": { "type": "boolean" },
        "mvc_003_active":      { "type": "boolean" },
        "day_open":            { "type": ["number","null"] },
        "day_high":            { "type": ["number","null"] },
        "day_low":             { "type": ["number","null"] },
        "day_range_vs_atr14":  { "type": ["number","null"] }
      }
    },
    "model_evaluations": {
      "type": "object",
      "properties": {
        "a1": { "$ref": "#/definitions/model_result" },
        "a3": { "$ref": "#/definitions/model_result" },
        "b1": { "$ref": "#/definitions/model_result" }
      }
    },
    "ade_decision": {
      "type": "object",
      "properties": {
        "has_candidate":       { "type": "boolean" },
        "candidate_model":     { "type": "string" },
        "winning_edge_score":  { "type": ["number","null"] },
        "confidence_level":    { "type": "string", "enum": ["HIGH","MEDIUM","LOW"] },
        "ranking_order":       { "type": "string" },
        "decision_rationale":  { "type": "string" },
        "no_trade_rationale":  { "type": ["string","null"] }
      }
    },
    "ari_decision": {
      "type": "object",
      "properties": {
        "approved":              { "type": "boolean" },
        "base_risk":             { "type": ["number","null"] },
        "risk_multiplier":       { "type": ["number","null"] },
        "approved_risk":         { "type": ["number","null"] },
        "contracts":             { "type": "integer" },
        "daily_pnl":             { "type": ["number","null"] },
        "daily_trade_count":     { "type": "integer" },
        "consecutive_losses":    { "type": "integer" },
        "consecutive_wins":      { "type": "integer" },
        "current_drawdown":      { "type": ["number","null"] },
        "circuit_breaker":       { "type": "boolean" },
        "active_position":       { "type": "boolean" },
        "triggered_rule":        { "type": ["string","null"] },
        "rejection_reason":      { "type": ["string","null"] },
        "remaining_daily_risk":  { "type": ["number","null"] }
      }
    },
    "tvl_decision": {
      "type": "object",
      "properties": {
        "status":                  { "type": "string", "enum": ["VERIFIED","REJECTED","DELAYED","EMERGENCY_BLOCK","NOT_EVALUATED"] },
        "verified":                { "type": "boolean" },
        "blocking_rule":           { "type": ["string","null"] },
        "rejection_reason":        { "type": ["string","null"] },
        "duplicate_status":        { "type": "boolean" },
        "session_valid":           { "type": "boolean" },
        "timestamp_valid":         { "type": "boolean" },
        "trade_parameters_valid":  { "type": "boolean" },
        "execution_permission":    { "type": "boolean" }
      }
    },
    "position_state": {
      "type": "object",
      "properties": {
        "trade_id":       { "type": "string" },
        "signal_id":      { "type": "string" },
        "model_id":       { "type": "string" },
        "status":         { "type": "string" },
        "direction":      { "type": "integer", "enum": [-1, 0, 1] },
        "contracts":      { "type": "integer" },
        "entry_price":    { "type": ["number","null"] },
        "fill_price":     { "type": ["number","null"] },
        "stop_price":     { "type": ["number","null"] },
        "target_price":   { "type": ["number","null"] },
        "current_pnl":    { "type": ["number","null"] },
        "current_r":      { "type": ["number","null"] },
        "mfe":            { "type": ["number","null"] },
        "mae":            { "type": ["number","null"] },
        "bars_in_trade":  { "type": "integer" },
        "exit_reason":    { "type": ["string","null"] }
      }
    },
    "reasoning": {
      "type": "object",
      "description": "Human-readable rationale strings for Atlas Brain View",
      "properties": {
        "market_state_summary":  { "type": "string" },
        "a1_rationale":          { "type": "string" },
        "a3_rationale":          { "type": "string" },
        "b1_rationale":          { "type": "string" },
        "ade_rationale":         { "type": "string" },
        "ari_rationale":         { "type": "string" },
        "tvl_rationale":         { "type": "string" },
        "action_summary":        { "type": "string" }
      }
    }
  },
  "definitions": {
    "model_result": {
      "type": "object",
      "properties": {
        "model_id":         { "type": "string" },
        "enabled":          { "type": "boolean" },
        "has_signal":       { "type": "boolean" },
        "direction":        { "type": "integer", "enum": [-1, 0, 1] },
        "edge_score":       { "type": ["number","null"] },
        "entry_price":      { "type": ["number","null"] },
        "stop_price":       { "type": ["number","null"] },
        "target_price":     { "type": ["number","null"] },
        "risk_points":      { "type": ["number","null"] },
        "reward_to_risk":   { "type": ["number","null"] },
        "signal_basis":     { "type": ["string","null"] },
        "rejection_reason": { "type": ["string","null"] }
      }
    }
  }
}
