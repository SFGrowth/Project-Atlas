//@version=6
// ============================================================
//  ATLAS UNIFIED PORTFOLIO STRATEGY
//  Version : 1.0.2
//  Build   : 2026-07-15
//  Author  : Atlas Nexus / DARWIN
// ============================================================
//
//  Single-script, single-webhook portfolio manager for MNQ futures.
//  Strategies: A1 · A3 · SB1 · ORB-1 · B1 · S109-001
//
//  ADE Selection Hierarchy (highest score wins):
//    A1       → score = ADX value           (TRENDING regime, RTH)
//    A3       → score = ADX × 0.95          (TRENDING regime, RTH)
//    SB1      → score = 50 (fixed)          (TRENDING, AM_MID, RAS)
//    ORB-1    → score = 45 (fixed)          (VOLATILE, AM_OPEN, RTH)
//    S109-001 → score = |VWAP dev|/ATR×100  (RTH, VWAP deviation ≥ 0.5×ATR)
//    B1       → score = 1  (fallback)
//
//  Webhook: set alert message to {{strategy.order.alert_message}}
//           The comment field carries the full JSON payload.
// ============================================================

strategy("Atlas Unified Portfolio Strategy", shorttitle="ATLAS-PORT", overlay=true, calc_on_every_tick=false, default_qty_type=strategy.fixed, default_qty_value=1, currency=currency.USD, commission_type=strategy.commission.cash_per_contract, commission_value=0.62)

// ============================================================
// SECTION 1 — INPUTS
// ============================================================

// — Portfolio Controls —
var string GRP_PORT = "Portfolio"
i_enable_portfolio = input.bool(true,  "Enable Portfolio Execution",  group=GRP_PORT)
i_enable_a1        = input.bool(true,  "Enable A1",                   group=GRP_PORT)
i_enable_a3        = input.bool(true,  "Enable A3",                   group=GRP_PORT)
i_enable_sb1       = input.bool(true,  "Enable SB1",                  group=GRP_PORT)
i_enable_orb1      = input.bool(true,  "Enable ORB-1",                group=GRP_PORT)
i_enable_s109      = input.bool(true,  "Enable S109-001",             group=GRP_PORT)
i_enable_b1        = input.bool(true,  "Enable B1 (fallback)",        group=GRP_PORT)

// — Session —
var string GRP_SESS = "Session"
i_rth_start = input.session("0930-1600", "RTH Session",   group=GRP_SESS)
i_am_open   = input.session("0930-1000", "AM Open",       group=GRP_SESS)
i_am_mid    = input.session("1000-1100", "AM Mid",        group=GRP_SESS)

// — Indicators —
var string GRP_IND = "Indicators"
i_adx_len     = input.int(14,  "ADX Length",         minval=5,  maxval=50, group=GRP_IND)
i_adx_thresh  = input.float(25.0, "ADX Threshold",   minval=10, maxval=60, group=GRP_IND)
i_atr_len     = input.int(14,  "ATR Length",         minval=5,  maxval=50, group=GRP_IND)
i_rsi_len     = input.int(14,  "RSI Length",         minval=5,  maxval=50, group=GRP_IND)
i_vwap_dev_mult = input.float(0.5, "VWAP Dev Multiplier (S109)", minval=0.1, maxval=2.0, group=GRP_IND)

// — Risk —
var string GRP_RISK = "Risk"
i_risk_per_trade = input.float(450.0, "Max Risk Per Trade ($)", minval=50, maxval=2000, group=GRP_RISK)
i_tick_value     = input.float(0.50,  "Tick Value ($)",         minval=0.01,            group=GRP_RISK)
i_tick_size      = input.float(0.25,  "Tick Size (pts)",        minval=0.01,            group=GRP_RISK)

// — Visuals —
var string GRP_VIS = "Visuals"
i_show_labels = input.bool(true,  "Show Entry Labels",  group=GRP_VIS)
i_show_lines  = input.bool(true,  "Show Trade Lines",   group=GRP_VIS)
i_show_table  = input.bool(true,  "Show Debug Table",   group=GRP_VIS)

// — Webhook —
var string GRP_WH = "Webhook"
i_environment   = input.string("paper",   "Environment",    options=["paper","live"], group=GRP_WH)
i_account_alias = input.string("MNQ-001", "Account Alias",  group=GRP_WH)

// ============================================================
// SECTION 2 — INDICATORS
// ============================================================

// ATR
atr = ta.atr(i_atr_len)

// ADX (Wilder)
[diPlus, diMinus, adxVal] = ta.dmi(i_adx_len, i_adx_len)

// RSI
rsiVal = ta.rsi(close, i_rsi_len)

// VWAP
vwapVal = ta.vwap(hlc3)
vwapDev = close - vwapVal

// EMA slope proxy
ema9      = ta.ema(close, 9)
ema9Slope = ema9 - ema9[1]

// ============================================================
// SECTION 3 — SESSION FLAGS
// ============================================================

isRTH    = not na(time(timeframe.period, i_rth_start))
isAMOpen = not na(time(timeframe.period, i_am_open))
isAMMid  = not na(time(timeframe.period, i_am_mid))

// ============================================================
// SECTION 4 — REGIME CLASSIFICATION
// ============================================================

isTrending = adxVal >= i_adx_thresh
isVolatile = atr > ta.sma(atr, 20) * 1.2

// Overnight inventory proxy (from trend direction)
// BULLISH → LONG, BEARISH → SHORT, else NEUTRAL
ovLong    = ema9Slope > 0 and close > vwapVal
ovShort   = ema9Slope < 0 and close < vwapVal

// ============================================================
// SECTION 5 — STRATEGY ELIGIBILITY
// ============================================================

// A1: TRENDING regime, RTH, long or short
a1Long  = i_enable_a1 and isTrending and isRTH and diPlus > diMinus
a1Short = i_enable_a1 and isTrending and isRTH and diMinus > diPlus
a1Elig  = a1Long or a1Short
a1Score = adxVal

// A3: same as A1 with 5% score haircut
a3Long  = i_enable_a3 and isTrending and isRTH and diPlus > diMinus
a3Short = i_enable_a3 and isTrending and isRTH and diMinus > diPlus
a3Elig  = a3Long or a3Short
a3Score = adxVal * 0.95

// SB1: TRENDING + AM_MID + RAS (use ema9Slope as RAS proxy)
sb1Long  = i_enable_sb1 and isTrending and isAMMid and ema9Slope > 0
sb1Short = i_enable_sb1 and isTrending and isAMMid and ema9Slope < 0
sb1Elig  = sb1Long or sb1Short
sb1Score = 50.0

// ORB-1: VOLATILE + AM_OPEN + RTH
orb1Long  = i_enable_orb1 and isVolatile and isAMOpen and isRTH and close > open
orb1Short = i_enable_orb1 and isVolatile and isAMOpen and isRTH and close < open
orb1Elig  = orb1Long or orb1Short
orb1Score = 45.0

// S109-001: RTH + VWAP deviation ≥ threshold + OV inventory aligned + RSI aligned
s109DevAbs  = math.abs(vwapDev)
s109DevOk   = s109DevAbs >= i_vwap_dev_mult * atr
s109Long    = i_enable_s109 and isRTH and s109DevOk and vwapDev > 0 and ovLong and rsiVal > 50
s109Short   = i_enable_s109 and isRTH and s109DevOk and vwapDev < 0 and ovShort and rsiVal < 50
s109Elig    = s109Long or s109Short
s109Score   = s109DevAbs / atr * 100

// B1: fallback — always eligible in RTH
b1Long  = i_enable_b1 and isRTH and close > vwapVal
b1Short = i_enable_b1 and isRTH and close < vwapVal
b1Elig  = b1Long or b1Short
b1Score = 1.0

// ============================================================
// SECTION 6 — ADE PROPOSAL SELECTION
// ============================================================

// Each eligible model submits a proposal; highest score wins.
// Single-active-strategy rule: no new entry while position is open.

hasPosition = strategy.position_size != 0

// Determine winner (descending score priority)
var string winModel = ""
var bool   winLong  = false
var float  winScore = 0.0

winModel := ""
winLong  := false
winScore := 0.0

if i_enable_portfolio and not hasPosition and barstate.isconfirmed
    // A1
    if a1Elig and a1Score > winScore
        winModel := "A1"
        winLong  := a1Long
        winScore := a1Score
    // A3 (only if A1 not already winning with same direction)
    if a3Elig and a3Score > winScore
        winModel := "A3"
        winLong  := a3Long
        winScore := a3Score
    // SB1
    if sb1Elig and sb1Score > winScore
        winModel := "SB1"
        winLong  := sb1Long
        winScore := sb1Score
    // ORB-1
    if orb1Elig and orb1Score > winScore
        winModel := "ORB-1"
        winLong  := orb1Long
        winScore := orb1Score
    // S109-001
    if s109Elig and s109Score > winScore
        winModel := "S109-001"
        winLong  := s109Long
        winScore := s109Score
    // B1 (fallback — only wins if nothing else eligible)
    if b1Elig and b1Score > winScore
        winModel := "B1"
        winLong  := b1Long
        winScore := b1Score

entryLong  = winModel != "" and winLong
entryShort = winModel != "" and not winLong

// ============================================================
// SECTION 7 — RISK CALCULATION
// ============================================================

// Stop distances by model
stopDist =
     winModel == "A1"      ? atr * 2.0 :
     winModel == "A3"      ? atr * 2.0 :
     winModel == "SB1"     ? atr * 1.5 :
     winModel == "ORB-1"   ? atr * 1.8 :
     winModel == "S109-001"? atr * 2.5 :
     atr * 2.0  // B1

// Target distances by model (R:R)
targetDist =
     winModel == "A1"      ? stopDist * 2.0 :
     winModel == "A3"      ? stopDist * 2.0 :
     winModel == "SB1"     ? stopDist * 2.5 :
     winModel == "ORB-1"   ? stopDist * 2.0 :
     winModel == "S109-001"? stopDist * 2.0 :
     stopDist * 1.5  // B1

entryPx  = close
stopPx   = winLong ? entryPx - stopDist  : entryPx + stopDist
targetPx = winLong ? entryPx + targetDist : entryPx - targetDist

// Contracts
ticksRisk  = stopDist / i_tick_size
riskPerCon = ticksRisk * i_tick_value
contracts  = math.max(1, math.floor(i_risk_per_trade / riskPerCon))

// ============================================================
// SECTION 8 — EXECUTION
// ============================================================

// Build a compact payload string for the alert message comment.
// alertcondition requires const string — we use strategy.entry's
// comment parameter to carry the runtime JSON payload.
// The alert message itself uses {{strategy.order.alert_message}}.

payloadDir    = winLong ? "long" : "short"
payloadModel  = winModel
payloadEnv    = i_environment
payloadAcct   = i_account_alias

if entryLong
    strategy.entry("LONG",  strategy.long,  qty=contracts,
         comment='{"event":"entry","strategy_id":"' + payloadModel + '","direction":"long","entry":' + str.tostring(entryPx, "#.##") + ',"stop":' + str.tostring(stopPx, "#.##") + ',"target":' + str.tostring(targetPx, "#.##") + ',"score":' + str.tostring(winScore, "#.##") + ',"contracts":' + str.tostring(contracts) + ',"environment":"' + payloadEnv + '","account":"' + payloadAcct + '","rule_hash":"ATLAS-PORT-117-2026-07-15"}')
    strategy.exit("LONG-EXIT", from_entry="LONG", stop=stopPx, limit=targetPx)

if entryShort
    strategy.entry("SHORT", strategy.short, qty=contracts,
         comment='{"event":"entry","strategy_id":"' + payloadModel + '","direction":"short","entry":' + str.tostring(entryPx, "#.##") + ',"stop":' + str.tostring(stopPx, "#.##") + ',"target":' + str.tostring(targetPx, "#.##") + ',"score":' + str.tostring(winScore, "#.##") + ',"contracts":' + str.tostring(contracts) + ',"environment":"' + payloadEnv + '","account":"' + payloadAcct + '","rule_hash":"ATLAS-PORT-117-2026-07-15"}')
    strategy.exit("SHORT-EXIT", from_entry="SHORT", stop=stopPx, limit=targetPx)

// ============================================================
// SECTION 9 — ALERT CONDITIONS
// ============================================================
// Set alert message to: {{strategy.order.alert_message}}
// The JSON payload is in the strategy.entry comment field above.

alertcondition(entryLong,  "ATLAS PORTFOLIO LONG ENTRY",  "ATLAS LONG ENTRY — check strategy comment for payload")
alertcondition(entryShort, "ATLAS PORTFOLIO SHORT ENTRY", "ATLAS SHORT ENTRY — check strategy comment for payload")

// ============================================================
// SECTION 10 — CHART VISUALISATION
// ============================================================

colA1   = color.new(#00B4D8, 0)
colA3   = color.new(#0077B6, 0)
colSB1  = color.new(#7B2FBE, 0)
colORB1 = color.new(#F4A261, 0)
colS109 = color.new(#2EC4B6, 0)
colB1   = color.new(#6C757D, 0)

winColor =
     winModel == "A1"      ? colA1   :
     winModel == "A3"      ? colA3   :
     winModel == "SB1"     ? colSB1  :
     winModel == "ORB-1"   ? colORB1 :
     winModel == "S109-001"? colS109 :
     colB1

// Entry labels
if i_show_labels and entryLong
    label.new(bar_index, low - atr * 0.5,
         text="▲ " + winModel + "\n" + str.tostring(winScore, "#.0"),
         color=winColor, textcolor=color.white, style=label.style_label_up, size=size.small)

if i_show_labels and entryShort
    label.new(bar_index, high + atr * 0.5,
         text="▼ " + winModel + "\n" + str.tostring(winScore, "#.0"),
         color=winColor, textcolor=color.white, style=label.style_label_down, size=size.small)

// Trade lines (stop / target)
var line lEntry  = na
var line lStop   = na
var line lTarget = na

if i_show_lines
    if not na(lEntry)
        line.delete(lEntry)
    if not na(lStop)
        line.delete(lStop)
    if not na(lTarget)
        line.delete(lTarget)

    if entryLong or entryShort
        lEntry  := line.new(bar_index, entryPx,  bar_index + 10, entryPx,  color=winColor,                    width=1, style=line.style_solid)
        lStop   := line.new(bar_index, stopPx,   bar_index + 10, stopPx,   color=color.new(#EF476F, 20),      width=1, style=line.style_dashed)
        lTarget := line.new(bar_index, targetPx, bar_index + 10, targetPx, color=color.new(#06D6A0, 20),      width=1, style=line.style_dashed)

// ============================================================
// SECTION 11 — DEBUG TABLE
// ============================================================

if i_show_table and barstate.islast
    var table t = table.new(position.top_right, 3, 10,
         bgcolor=color.new(color.black, 80), border_width=1, border_color=color.new(color.gray, 50))

    table.cell(t, 0, 0, "MODEL",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 0, "ELIG",    text_color=color.gray,  text_size=size.small)
    table.cell(t, 2, 0, "SCORE",   text_color=color.gray,  text_size=size.small)

    models = array.from("A1","A3","SB1","ORB-1","S109-001","B1")
    eligs  = array.from(a1Elig, a3Elig, sb1Elig, orb1Elig, s109Elig, b1Elig)
    scores = array.from(a1Score, a3Score, sb1Score, orb1Score, s109Score, b1Score)

    for i = 0 to 5
        mdl   = array.get(models, i)
        elig  = array.get(eligs,  i)
        scr   = array.get(scores, i)
        isWin = mdl == winModel

        rowCol = isWin ? color.new(#00FF88, 0) : elig ? color.white : color.new(color.gray, 40)

        table.cell(t, 0, i + 1, mdl,                                    text_color=rowCol, text_size=size.small)
        table.cell(t, 1, i + 1, elig ? "YES" : "no",                   text_color=rowCol, text_size=size.small)
        table.cell(t, 2, i + 1, str.tostring(scr, "#.0"),              text_color=rowCol, text_size=size.small)

    table.cell(t, 0, 8, "WINNER",                                       text_color=color.yellow, text_size=size.small)
    table.cell(t, 1, 8, winModel == "" ? "—" : winModel,               text_color=color.yellow, text_size=size.small)
    table.cell(t, 2, 8, str.tostring(winScore, "#.0"),                  text_color=color.yellow, text_size=size.small)

    table.cell(t, 0, 9, "ADX / RSI",                                    text_color=color.gray,   text_size=size.small)
    table.cell(t, 1, 9, str.tostring(adxVal, "#.0"),                    text_color=color.white,  text_size=size.small)
    table.cell(t, 2, 9, str.tostring(rsiVal, "#.0"),                    text_color=color.white,  text_size=size.small)
