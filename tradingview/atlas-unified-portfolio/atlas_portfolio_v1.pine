// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  ATLAS UNIFIED PORTFOLIO STRATEGY  v1.0.0                                   ║
// ║  Atlas Portfolio Pine — Sprint 117                                           ║
// ║                                                                              ║
// ║  One script. One webhook. One alert. Complete portfolio.                     ║
// ║                                                                              ║
// ║  INCLUDED STRATEGIES (certified portfolio, Sprint 117):                      ║
// ║    A1     — Trending regime, ADX-scored, RTH                                 ║
// ║    A3     — Trending regime, ADX × 0.95, RTH                                 ║
// ║    SB1    — Trending + AM_MID + RAS activation, score 50                     ║
// ║    ORB-1  — Volatile + AM_OPEN, score 45                                     ║
// ║    S109-001 — VWAP deviation + RSI + OV inventory, RTH                       ║
// ║    B1     — Baseline fallback, score 1.0                                     ║
// ║                                                                              ║
// ║  ADE SCORING (exact parity with Atlas server-side ADE):                      ║
// ║    A1:      score = ADX                                                      ║
// ║    A3:      score = ADX × 0.95                                               ║
// ║    SB1:     score = 50.0 (fixed)                                             ║
// ║    ORB-1:   score = 45.0 (fixed)                                             ║
// ║    S109-001: score = |VWAP_deviation| / ATR14 × 100                          ║
// ║    B1:      score = 1.0 (fixed)                                              ║
// ║                                                                              ║
// ║  INVARIANTS:                                                                 ║
// ║    • One active portfolio position at a time                                 ║
// ║    • Highest ADE score wins on each bar                                      ║
// ║    • ADE is the final authority — Pine is signal-generation only             ║
// ║    • No repainting. No lookahead. Confirmed-bar logic.                       ║
// ║    • All events carry deterministic event IDs                                ║
// ║    • strategy_id identifies the winning model in every payload               ║
// ║                                                                              ║
// ║  RULE HASH: sha256(A1:TRENDING+RTH+ADX|A3:TRENDING+RTH+ADX*0.95|            ║
// ║             SB1:TRENDING+AM_MID+RAS+50|ORB1:VOLATILE+AM_OPEN+45|            ║
// ║             S109:RTH+VWAP>0.5ATR+OV+SLOPE+RSI+2.5ATR_STOP+2.0ATR_TGT|      ║
// ║             B1:FALLBACK+1.0)                                                 ║
// ║  BUILD: 2026-07-15                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

//@version=5
strategy(
    title            = "Atlas Unified Portfolio Strategy",
    shorttitle       = "ATLAS-PORT",
    overlay          = true,
    calc_on_every_tick = false,
    process_exits_on_close = false,
    default_qty_type = strategy.fixed,
    default_qty_value = 1,
    initial_capital  = 50000,
    commission_type  = strategy.commission.cash_per_contract,
    commission_value = 2.0,
    slippage         = 1
)

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 1 — INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// ── Portfolio Controls ────────────────────────────────────────────────────────
var string GRP_PORT = "Portfolio"
i_enable_portfolio = input.bool(true,  "Enable Portfolio Execution",    group=GRP_PORT)
i_enable_a1        = input.bool(true,  "Enable A1",                     group=GRP_PORT)
i_enable_a3        = input.bool(true,  "Enable A3",                     group=GRP_PORT)
i_enable_sb1       = input.bool(true,  "Enable SB1",                    group=GRP_PORT)
i_enable_orb1      = input.bool(true,  "Enable ORB-1",                  group=GRP_PORT)
i_enable_s109      = input.bool(true,  "Enable S109-001",               group=GRP_PORT)
i_enable_b1        = input.bool(true,  "Enable B1",                     group=GRP_PORT)
i_mode             = input.string("PAPER", "Mode (PAPER/APEX/LIVE)",    group=GRP_PORT, options=["PAPER","APEX","LIVE"])
i_qty              = input.int(1,      "Contract Quantity",             group=GRP_PORT, minval=1, maxval=10)
i_confirmed_bar    = input.bool(true,  "Confirmed-Bar Execution",       group=GRP_PORT, tooltip="Use bar[1] for all signals to prevent repainting")

// ── Risk ──────────────────────────────────────────────────────────────────────
var string GRP_RISK = "Risk"
i_dollar_risk      = input.float(450.0, "Dollar Risk Per Trade ($)",    group=GRP_RISK, minval=50, maxval=5000)
i_point_value      = input.float(2.0,   "MNQ Point Value ($)",         group=GRP_RISK)

// ── Indicator Parameters ──────────────────────────────────────────────────────
var string GRP_IND = "Indicators"
i_adx_len          = input.int(14,  "ADX Length",                       group=GRP_IND)
i_adx_smooth       = input.int(14,  "ADX Smoothing",                    group=GRP_IND)
i_adx_trend_min    = input.float(25.0, "ADX Trending Threshold",        group=GRP_IND, tooltip="ADX above this = TRENDING regime")
i_adx_strong       = input.float(50.0, "ADX Strong Threshold",          group=GRP_IND, tooltip="ADX above this = A1 strongly preferred")
i_atr_len          = input.int(14,  "ATR Length",                       group=GRP_IND)
i_rsi_len          = input.int(14,  "RSI Length",                       group=GRP_IND)
i_ema9_len         = input.int(9,   "EMA9 Length (VWAP slope proxy)",   group=GRP_IND)
i_vwap_dev_min     = input.float(0.5, "S109 Min VWAP Deviation (×ATR)", group=GRP_IND, tooltip="S109-001 requires |close-VWAP| > this × ATR14")

// ── Session Times (ET) ────────────────────────────────────────────────────────
var string GRP_SESS = "Sessions"
i_rth_start        = input.session("0930-1600", "RTH Session",          group=GRP_SESS)
i_am_open_end      = input.int(1000, "AM_OPEN ends (HHMM ET)",          group=GRP_SESS, tooltip="09:30–10:00 = ORB-1 window")
i_am_mid_start     = input.int(1000, "AM_MID starts (HHMM ET)",         group=GRP_SESS, tooltip="10:00–11:00 = SB1 window")
i_am_mid_end       = input.int(1100, "AM_MID ends (HHMM ET)",           group=GRP_SESS)

// ── Visuals ───────────────────────────────────────────────────────────────────
var string GRP_VIZ = "Visuals"
i_show_entries     = input.bool(true,  "Show Entry Labels",             group=GRP_VIZ)
i_show_exits       = input.bool(true,  "Show Exit Labels",              group=GRP_VIZ)
i_show_lines       = input.bool(true,  "Show Trade Lines",              group=GRP_VIZ)
i_show_boxes       = input.bool(true,  "Show R/R Boxes",                group=GRP_VIZ)
i_show_scores      = input.bool(true,  "Show Scores on Labels",         group=GRP_VIZ)
i_show_regimes     = input.bool(false, "Show Regime Background",        group=GRP_VIZ)
i_show_blocked     = input.bool(false, "Show Blocked Signal Markers",   group=GRP_VIZ)
i_show_debug       = input.bool(false, "Show Debug Table",              group=GRP_VIZ)
i_show_vwap        = input.bool(true,  "Show VWAP",                     group=GRP_VIZ)
i_show_ema9        = input.bool(false, "Show EMA9",                     group=GRP_VIZ)

// ── Webhook ───────────────────────────────────────────────────────────────────
var string GRP_WH = "Webhook"
i_webhook_enabled  = input.bool(true,  "Webhook Messaging Enabled",     group=GRP_WH)
i_environment      = input.string("paper", "Environment",               group=GRP_WH, options=["paper","apex","live"])
i_account_alias    = input.string("ATLAS_MNQ", "Account Alias",         group=GRP_WH)
i_portfolio_ver    = input.string("1.0.0", "Portfolio Version",         group=GRP_WH)
// NOTE: Never place API credentials in Pine source code.
// The webhook URL is configured in the TradingView alert, not here.

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 2 — INDICATORS
// ══════════════════════════════════════════════════════════════════════════════

// ── ATR ───────────────────────────────────────────────────────────────────────
atr14 = ta.atr(i_atr_len)

// ── ADX ───────────────────────────────────────────────────────────────────────
[diPlus, diMinus, adxVal] = ta.dmi(i_adx_len, i_adx_smooth)

// ── RSI ───────────────────────────────────────────────────────────────────────
rsi14 = ta.rsi(close, i_rsi_len)

// ── VWAP ─────────────────────────────────────────────────────────────────────
vwapVal = ta.vwap(hlc3)

// ── EMA9 (VWAP slope proxy) ───────────────────────────────────────────────────
ema9 = ta.ema(close, i_ema9_len)
ema9Slope = ema9 - ema9[3]  // 3-bar slope (same as server-side vwapSlope3Bar)

// ── Session classification ────────────────────────────────────────────────────
isRth      = not na(time(timeframe.period, i_rth_start, "America/New_York"))
barHHMM    = (hour(time, "America/New_York") * 100) + minute(time, "America/New_York")
isAmOpen   = isRth and barHHMM >= 930  and barHHMM < i_am_open_end
isAmMid    = isRth and barHHMM >= i_am_mid_start and barHHMM < i_am_mid_end
isRthOther = isRth and not isAmOpen and not isAmMid

// Session string for webhook
sessionStr = isAmOpen ? "AM_OPEN" : isAmMid ? "AM_MID" : isRth ? "RTH" : "OV"

// ── Regime classification ─────────────────────────────────────────────────────
// Mirrors M-16 regime logic: TRENDING when ADX > threshold + directional
isTrending  = adxVal > i_adx_trend_min
isVolatile  = atr14 > atr14[5] * 1.3  // ATR expansion proxy for VOLATILE
isChoppy    = not isTrending and not isVolatile
regimeStr   = isTrending ? (diPlus > diMinus ? "TRENDING_BULL" : "TRENDING_BEAR") :
              isVolatile ? "VOLATILE" : isChoppy ? "CHOPPY" : "RANGING"

// ── Direction from regime ─────────────────────────────────────────────────────
regimeLong  = isTrending and diPlus > diMinus
regimeShort = isTrending and diMinus > diPlus

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 3 — STRATEGY ELIGIBILITY
// ══════════════════════════════════════════════════════════════════════════════

// Use confirmed-bar values when i_confirmed_bar is true (prevents repainting)
_adx   = i_confirmed_bar ? adxVal[1]   : adxVal
_atr   = i_confirmed_bar ? atr14[1]    : atr14
_rsi   = i_confirmed_bar ? rsi14[1]    : rsi14
_vwap  = i_confirmed_bar ? vwapVal[1]  : vwapVal
_close = i_confirmed_bar ? close[1]    : close
_ema9s = i_confirmed_bar ? ema9Slope[1]: ema9Slope
_diP   = i_confirmed_bar ? diPlus[1]   : diPlus
_diM   = i_confirmed_bar ? diMinus[1]  : diMinus
_isRth = i_confirmed_bar ? isRth[1]    : isRth
_isAmOpen = i_confirmed_bar ? isAmOpen[1] : isAmOpen
_isAmMid  = i_confirmed_bar ? isAmMid[1]  : isAmMid
_isTrend  = i_confirmed_bar ? isTrending[1] : isTrending
_isVol    = i_confirmed_bar ? isVolatile[1] : isVolatile
_regime   = i_confirmed_bar ? regimeStr[1]  : regimeStr
_regLong  = i_confirmed_bar ? regimeLong[1] : regimeLong
_regShort = i_confirmed_bar ? regimeShort[1]: regimeShort

// ── A1 Eligibility ────────────────────────────────────────────────────────────
// Rule: TRENDING regime + RTH session
a1Eligible = i_enable_a1 and _isTrend and _isRth
a1Score    = a1Eligible ? _adx : 0.0
a1Long     = a1Eligible and _regLong
a1Short    = a1Eligible and _regShort

// ── A3 Eligibility ────────────────────────────────────────────────────────────
// Rule: TRENDING regime + RTH session (same as A1, slightly lower score)
a3Eligible = i_enable_a3 and _isTrend and _isRth
a3Score    = a3Eligible ? _adx * 0.95 : 0.0
a3Long     = a3Eligible and _regLong
a3Short    = a3Eligible and _regShort

// ── SB1 Eligibility ───────────────────────────────────────────────────────────
// Rule: TRENDING + AM_MID session (10:00–11:00 ET) + RAS activation
// RAS proxy: ADX > 30 + directional (simplified — full RAS requires 9 components)
rasActivated = _adx > 30.0 and _isTrend
sb1Eligible  = i_enable_sb1 and _isTrend and _isAmMid and rasActivated
sb1Score     = sb1Eligible ? 50.0 : 0.0
sb1Long      = sb1Eligible and _regLong
sb1Short     = sb1Eligible and _regShort

// ── ORB-1 Eligibility ─────────────────────────────────────────────────────────
// Rule: VOLATILE regime + AM_OPEN session (09:30–10:00 ET) + RTH
orb1Eligible = i_enable_orb1 and _isVol and _isAmOpen and _isRth
orb1Score    = orb1Eligible ? 45.0 : 0.0
// ORB-1 direction: breakout above prior high = LONG, below prior low = SHORT
orb1High     = ta.highest(high, 5)
orb1Low      = ta.lowest(low, 5)
orb1Long     = orb1Eligible and _close > (i_confirmed_bar ? orb1High[1] : orb1High)
orb1Short    = orb1Eligible and _close < (i_confirmed_bar ? orb1Low[1] : orb1Low)

// ── S109-001 Eligibility ──────────────────────────────────────────────────────
// Rule: RTH only, |close - VWAP| > 0.5×ATR14, OV inventory aligned, VWAP slope aligned, RSI confirmation
// OV inventory proxy: EMA9 slope direction (BULLISH=positive slope → LONG bias)
vwapDev      = _close - _vwap
absVwapDev   = math.abs(vwapDev)
s109DevOk    = absVwapDev >= i_vwap_dev_min * _atr
s109Dir      = vwapDev > 0 ? 1 : -1  // 1=LONG, -1=SHORT
// OV inventory alignment (proxy: EMA9 slope direction)
ovLong       = _ema9s > 0
ovShort      = _ema9s < 0
s109OvOk     = (s109Dir == 1 and ovLong) or (s109Dir == -1 and ovShort)
// VWAP slope alignment (same as OV proxy in this implementation)
s109SlopeOk  = s109OvOk
// RSI confirmation
s109RsiOk    = (s109Dir == 1 and _rsi > 50) or (s109Dir == -1 and _rsi < 50)
// All filters must pass
s109Eligible = i_enable_s109 and _isRth and s109DevOk and s109OvOk and s109SlopeOk and s109RsiOk
// ADE score: |VWAP deviation| / ATR × 100
s109Score    = s109Eligible ? (absVwapDev / _atr * 100) : 0.0
s109Long     = s109Eligible and s109Dir == 1
s109Short    = s109Eligible and s109Dir == -1

// ── B1 Eligibility ────────────────────────────────────────────────────────────
// Rule: Baseline fallback — eligible in any RTH session
b1Eligible   = i_enable_b1 and _isRth
b1Score      = b1Eligible ? 1.0 : 0.0
b1Long       = b1Eligible and _regLong
b1Short      = b1Eligible and _regShort

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 4 — ADE PORTFOLIO SELECTION
// ══════════════════════════════════════════════════════════════════════════════

// Build score array — highest score wins
// Scores are only non-zero when the model is eligible
// This exactly mirrors the server-side ADE ranking in paperTradeEngine.ts

// Determine the winning model by finding the highest score
// Tie-breaking: A1 > A3 > SB1 > ORB-1 > S109-001 > B1 (alphabetical by sprint order)
// In practice, scores are designed to avoid ties

// Winner selection (cascade from highest to lowest score)
// We use a var to track the winner across the bar
winnerScore  = math.max(a1Score, a3Score, sb1Score, orb1Score, s109Score, b1Score)
hasWinner    = winnerScore > 0.0

// Identify winning model string
winnerIsA1   = hasWinner and a1Score   == winnerScore and a1Eligible
winnerIsA3   = hasWinner and not winnerIsA1 and a3Score  == winnerScore and a3Eligible
winnerIsSB1  = hasWinner and not winnerIsA1 and not winnerIsA3 and sb1Score  == winnerScore and sb1Eligible
winnerIsORB1 = hasWinner and not winnerIsA1 and not winnerIsA3 and not winnerIsSB1 and orb1Score == winnerScore and orb1Eligible
winnerIsS109 = hasWinner and not winnerIsA1 and not winnerIsA3 and not winnerIsSB1 and not winnerIsORB1 and s109Score == winnerScore and s109Eligible
winnerIsB1   = hasWinner and not winnerIsA1 and not winnerIsA3 and not winnerIsSB1 and not winnerIsORB1 and not winnerIsS109 and b1Score == winnerScore and b1Eligible

winnerModel  = winnerIsA1 ? "A1" : winnerIsA3 ? "A3" : winnerIsSB1 ? "SB1" :
               winnerIsORB1 ? "ORB-1" : winnerIsS109 ? "S109-001" : winnerIsB1 ? "B1" : "NONE"

// Direction of the winning model
winnerLong  = (winnerIsA1 and a1Long) or (winnerIsA3 and a3Long) or
              (winnerIsSB1 and sb1Long) or (winnerIsORB1 and orb1Long) or
              (winnerIsS109 and s109Long) or (winnerIsB1 and b1Long)
winnerShort = (winnerIsA1 and a1Short) or (winnerIsA3 and a3Short) or
              (winnerIsSB1 and sb1Short) or (winnerIsORB1 and orb1Short) or
              (winnerIsS109 and s109Short) or (winnerIsB1 and b1Short)

// ── Stop and Target Calculation ───────────────────────────────────────────────
// A1/A3/SB1/ORB-1/B1: 2.5×ATR stop, 2.0×ATR target (standard Atlas risk)
// S109-001: 2.5×ATR stop, 2.0×ATR target (frozen DARWIN parameters)
stopDist   = 2.5 * _atr
targetDist = 2.0 * _atr

entryPrice  = _close  // Next-bar open approximated as current close (confirmed bar)
stopLong    = entryPrice - stopDist
stopShort   = entryPrice + stopDist
targetLong  = entryPrice + targetDist
targetShort = entryPrice - targetDist

stopPrice   = winnerLong ? stopLong : stopShort
targetPrice = winnerLong ? targetLong : targetShort

// ── Contract Sizing ───────────────────────────────────────────────────────────
// Dollar-risk formula: floor(dollar_risk / (stop_pts × point_value))
stopPts     = stopDist
contracts   = math.max(1, math.floor(i_dollar_risk / (stopPts * i_point_value)))
finalQty    = math.min(contracts, i_qty)  // Cap at user-configured max

// ── Single-Active-Strategy Rule ───────────────────────────────────────────────
// No entry while a portfolio position is open
hasOpenPos  = strategy.position_size != 0

// ── Final Entry Signal ────────────────────────────────────────────────────────
canEnter    = i_enable_portfolio and hasWinner and not hasOpenPos
entryLong   = canEnter and winnerLong
entryShort  = canEnter and winnerShort

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 5 — STRATEGY EXECUTION
// ══════════════════════════════════════════════════════════════════════════════

// ── Entry ─────────────────────────────────────────────────────────────────────
if entryLong
    strategy.entry("ATLAS_LONG", strategy.long, qty=finalQty, comment=winnerModel)
    strategy.exit("ATLAS_LONG_EXIT", "ATLAS_LONG",
                  stop=stopLong, limit=targetLong,
                  comment="EXIT")

if entryShort
    strategy.entry("ATLAS_SHORT", strategy.short, qty=finalQty, comment=winnerModel)
    strategy.exit("ATLAS_SHORT_EXIT", "ATLAS_SHORT",
                  stop=stopShort, limit=targetShort,
                  comment="EXIT")

// ── Session Flatten ───────────────────────────────────────────────────────────
// Close all positions at RTH close (15:55 ET)
barHHMM_now = (hour(time, "America/New_York") * 100) + minute(time, "America/New_York")
isRthClose  = barHHMM_now >= 1555 and barHHMM_now < 1600
if isRthClose and strategy.position_size != 0
    strategy.close_all(comment="SESSION_FLATTEN")

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 6 — DETERMINISTIC EVENT ID
// ══════════════════════════════════════════════════════════════════════════════

// Event ID: {symbol}_{strategy}_{direction}_{bar_time_unix}
// This is deterministic and idempotent — same bar always produces same ID.
// The Atlas webhook receiver uses this for deduplication.
eventIdBase = syminfo.ticker + "_" + winnerModel + "_" + (winnerLong ? "L" : "S") + "_" + str.tostring(time)

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 7 — WEBHOOK PAYLOAD GENERATION
// ══════════════════════════════════════════════════════════════════════════════

// Build JSON payload for entry events.
// This is the message text used in the TradingView alert.
// All fields mirror the Sprint 117 webhook schema exactly.

entryPayload = '{"source":"tradingview","system":"atlas","script":"atlas_portfolio","script_version":"' + i_portfolio_ver + '","event_id":"' + eventIdBase + '","event":"entry","strategy_id":"' + winnerModel + '","symbol":"MNQ","ticker":"{{ticker}}","timeframe":"{{interval}}","market_time":"{{time}}","side":"' + (winnerLong ? "buy" : "sell") + '","quantity":' + str.tostring(finalQty) + ',"entry_price":' + str.tostring(math.round(entryPrice, 2)) + ',"stop_price":' + str.tostring(math.round(stopPrice, 2)) + ',"target_price":' + str.tostring(math.round(targetPrice, 2)) + ',"risk_points":' + str.tostring(math.round(stopDist, 2)) + ',"risk_dollars":' + str.tostring(math.round(finalQty * stopDist * i_point_value, 2)) + ',"regime":"' + _regime + '","session":"' + sessionStr + '","score":' + str.tostring(math.round(winnerScore, 2)) + ',"reason":"' + winnerModel + ' selected by ADE portfolio ranking","bar_time":' + str.tostring(time) + ',"mode":"' + i_mode + '","account":"' + i_account_alias + '"}'

exitPayload  = '{"source":"tradingview","system":"atlas","script":"atlas_portfolio","script_version":"' + i_portfolio_ver + '","event_id":"' + syminfo.ticker + "_" + "EXIT_" + str.tostring(time) + '","event":"exit","strategy_id":"' + winnerModel + '","symbol":"MNQ","ticker":"{{ticker}}","timeframe":"{{interval}}","market_time":"{{time}}","bar_time":' + str.tostring(time) + ',"mode":"' + i_mode + '","account":"' + i_account_alias + '"}'

// Alert conditions — these are what you attach the webhook to in TradingView
alertcondition(entryLong,  "ATLAS PORTFOLIO LONG ENTRY",  entryPayload)
alertcondition(entryShort, "ATLAS PORTFOLIO SHORT ENTRY", entryPayload)

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 8 — CHART VISUALISATION
// ══════════════════════════════════════════════════════════════════════════════

// ── Strategy Colours ──────────────────────────────────────────────────────────
colA1    = color.new(#00B4D8, 0)   // Cyan
colA3    = color.new(#0077B6, 0)   // Deep blue
colSB1   = color.new(#7B2FBE, 0)   // Purple
colORB1  = color.new(#FF6B35, 0)   // Orange
colS109  = color.new(#06D6A0, 0)   // Teal-green
colB1    = color.new(#ADB5BD, 0)   // Grey (fallback)
colNone  = color.new(color.gray, 80)

winnerColor = winnerIsA1 ? colA1 : winnerIsA3 ? colA3 : winnerIsSB1 ? colSB1 :
              winnerIsORB1 ? colORB1 : winnerIsS109 ? colS109 : winnerIsB1 ? colB1 : colNone

// ── VWAP ─────────────────────────────────────────────────────────────────────
plot(i_show_vwap ? vwapVal : na, "VWAP", color=color.new(#FFD166, 80), linewidth=1)

// ── EMA9 ──────────────────────────────────────────────────────────────────────
plot(i_show_ema9 ? ema9 : na, "EMA9", color=color.new(#EF476F, 60), linewidth=1)

// ── Regime Background ─────────────────────────────────────────────────────────
bgcolor(i_show_regimes and isTrending ? color.new(color.blue, 95) : na, title="Trending Regime")
bgcolor(i_show_regimes and isVolatile ? color.new(color.orange, 95) : na, title="Volatile Regime")

// ── Entry Labels ──────────────────────────────────────────────────────────────
scoreText  = i_show_scores ? " [" + str.tostring(math.round(winnerScore, 1)) + "]" : ""
entryLabel = winnerModel + (winnerLong ? " ▲" : " ▼") + scoreText

if i_show_entries and entryLong
    label.new(bar_index, low - _atr * 0.3,
              text  = entryLabel,
              color = winnerColor,
              textcolor = color.white,
              style = label.style_label_up,
              size  = size.small)

if i_show_entries and entryShort
    label.new(bar_index, high + _atr * 0.3,
              text  = entryLabel,
              color = winnerColor,
              textcolor = color.white,
              style = label.style_label_down,
              size  = size.small)

// ── Blocked Signal Markers ────────────────────────────────────────────────────
blockedSignal = hasWinner and hasOpenPos and (winnerLong or winnerShort)
if i_show_blocked and blockedSignal
    label.new(bar_index, high + _atr * 0.5,
              text  = "⊘ " + winnerModel,
              color = color.new(color.gray, 60),
              textcolor = color.new(color.white, 40),
              style = label.style_label_down,
              size  = size.tiny)

// ── Trade Lines (entry, stop, target) ─────────────────────────────────────────
// Track open trade state
var float openEntryPrice  = na
var float openStopPrice   = na
var float openTargetPrice = na
var int   openEntryBar    = na
var string openModel      = na
var bool  openIsLong      = na
var line  entryLine       = na
var line  stopLine        = na
var line  targetLine      = na
var box   rrBox           = na

// On entry
if entryLong or entryShort
    openEntryPrice  := entryPrice
    openStopPrice   := stopPrice
    openTargetPrice := targetPrice
    openEntryBar    := bar_index
    openModel       := winnerModel
    openIsLong      := winnerLong

    if i_show_lines
        if not na(entryLine)
            line.delete(entryLine)
        if not na(stopLine)
            line.delete(stopLine)
        if not na(targetLine)
            line.delete(targetLine)
        entryLine  := line.new(bar_index, entryPrice,  bar_index + 1, entryPrice,
                               color=winnerColor, width=1, style=line.style_dashed)
        stopLine   := line.new(bar_index, stopPrice,   bar_index + 1, stopPrice,
                               color=color.new(#EF476F, 20), width=1, style=line.style_dotted)
        targetLine := line.new(bar_index, targetPrice, bar_index + 1, targetPrice,
                               color=color.new(#06D6A0, 20), width=1, style=line.style_dotted)

    if i_show_boxes
        if not na(rrBox)
            box.delete(rrBox)
        boxTop    = winnerLong ? targetPrice : entryPrice
        boxBottom = winnerLong ? entryPrice  : targetPrice
        rrBox := box.new(bar_index, boxTop, bar_index + 20, boxBottom,
                         border_color=color.new(winnerColor, 60),
                         bgcolor=color.new(winnerColor, 90),
                         text=openModel,
                         text_color=color.new(winnerColor, 20),
                         text_size=size.tiny)

// Extend lines while position is open
if not na(openEntryBar) and strategy.position_size != 0
    if i_show_lines
        if not na(entryLine)
            line.set_x2(entryLine, bar_index)
        if not na(stopLine)
            line.set_x2(stopLine, bar_index)
        if not na(targetLine)
            line.set_x2(targetLine, bar_index)
    if i_show_boxes and not na(rrBox)
        box.set_right(rrBox, bar_index)

// On exit
posClosedNow = strategy.position_size == 0 and strategy.position_size[1] != 0
if posClosedNow and i_show_exits and not na(openEntryPrice)
    exitPx    = strategy.closedtrades.exit_price(strategy.closedtrades.size() - 1)
    pnlPts    = openIsLong ? exitPx - openEntryPrice : openEntryPrice - exitPx
    rMult     = stopDist > 0 ? pnlPts / stopDist : 0
    exitType  = pnlPts > 0 ? "TARGET" : "STOP"
    exitText  = openModel + " " + exitType + "\n" +
                str.tostring(math.round(pnlPts, 2)) + " pts  " +
                str.tostring(math.round(rMult, 2)) + "R"
    exitColor = pnlPts > 0 ? color.new(#06D6A0, 0) : color.new(#EF476F, 0)
    label.new(bar_index, pnlPts > 0 ? high + _atr * 0.3 : low - _atr * 0.3,
              text      = exitText,
              color     = exitColor,
              textcolor = color.white,
              style     = pnlPts > 0 ? label.style_label_down : label.style_label_up,
              size      = size.small)
    // Reset open trade state
    openEntryPrice  := na
    openStopPrice   := na
    openTargetPrice := na
    openEntryBar    := na
    openModel       := na
    openIsLong      := na

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 9 — DEBUG TABLE
// ══════════════════════════════════════════════════════════════════════════════

if i_show_debug and barstate.islast
    var table dbg = table.new(position.top_right, 3, 12,
                              bgcolor=color.new(color.black, 70),
                              border_color=color.new(color.gray, 60),
                              border_width=1)

    // Header
    table.cell(dbg, 0, 0, "MODEL",     text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 1, 0, "ELIGIBLE",  text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 0, "SCORE",     text_color=color.gray, text_size=size.tiny)

    // A1
    table.cell(dbg, 0, 1, "A1",        text_color=colA1,  text_size=size.tiny)
    table.cell(dbg, 1, 1, a1Eligible ? "✓" : "✗",
               text_color=a1Eligible ? colA1 : color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 1, str.tostring(math.round(a1Score, 1)),
               text_color=winnerIsA1 ? color.white : color.gray, text_size=size.tiny)

    // A3
    table.cell(dbg, 0, 2, "A3",        text_color=colA3,  text_size=size.tiny)
    table.cell(dbg, 1, 2, a3Eligible ? "✓" : "✗",
               text_color=a3Eligible ? colA3 : color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 2, str.tostring(math.round(a3Score, 1)),
               text_color=winnerIsA3 ? color.white : color.gray, text_size=size.tiny)

    // SB1
    table.cell(dbg, 0, 3, "SB1",       text_color=colSB1, text_size=size.tiny)
    table.cell(dbg, 1, 3, sb1Eligible ? "✓" : "✗",
               text_color=sb1Eligible ? colSB1 : color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 3, str.tostring(math.round(sb1Score, 1)),
               text_color=winnerIsSB1 ? color.white : color.gray, text_size=size.tiny)

    // ORB-1
    table.cell(dbg, 0, 4, "ORB-1",     text_color=colORB1, text_size=size.tiny)
    table.cell(dbg, 1, 4, orb1Eligible ? "✓" : "✗",
               text_color=orb1Eligible ? colORB1 : color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 4, str.tostring(math.round(orb1Score, 1)),
               text_color=winnerIsORB1 ? color.white : color.gray, text_size=size.tiny)

    // S109-001
    table.cell(dbg, 0, 5, "S109-001",  text_color=colS109, text_size=size.tiny)
    table.cell(dbg, 1, 5, s109Eligible ? "✓" : "✗",
               text_color=s109Eligible ? colS109 : color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 5, str.tostring(math.round(s109Score, 1)),
               text_color=winnerIsS109 ? color.white : color.gray, text_size=size.tiny)

    // B1
    table.cell(dbg, 0, 6, "B1",        text_color=colB1,  text_size=size.tiny)
    table.cell(dbg, 1, 6, b1Eligible ? "✓" : "✗",
               text_color=b1Eligible ? colB1 : color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 6, str.tostring(math.round(b1Score, 1)),
               text_color=winnerIsB1 ? color.white : color.gray, text_size=size.tiny)

    // Separator
    table.cell(dbg, 0, 7, "─────",     text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 1, 7, "─────",     text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 7, "─────",     text_color=color.gray, text_size=size.tiny)

    // Winner
    table.cell(dbg, 0, 8, "WINNER",    text_color=color.white, text_size=size.tiny)
    table.cell(dbg, 1, 8, winnerModel, text_color=winnerColor, text_size=size.tiny)
    table.cell(dbg, 2, 8, str.tostring(math.round(winnerScore, 1)),
               text_color=color.white, text_size=size.tiny)

    // Direction
    table.cell(dbg, 0, 9, "DIR",       text_color=color.white, text_size=size.tiny)
    table.cell(dbg, 1, 9, winnerLong ? "LONG" : winnerShort ? "SHORT" : "—",
               text_color=winnerLong ? color.new(#06D6A0, 0) : winnerShort ? color.new(#EF476F, 0) : color.gray,
               text_size=size.tiny)
    table.cell(dbg, 2, 9, "",          text_color=color.gray, text_size=size.tiny)

    // Position state
    table.cell(dbg, 0, 10, "POS",      text_color=color.white, text_size=size.tiny)
    table.cell(dbg, 1, 10, hasOpenPos ? "OPEN" : "FLAT",
               text_color=hasOpenPos ? color.new(#FFD166, 0) : color.gray, text_size=size.tiny)
    table.cell(dbg, 2, 10, str.tostring(math.round(strategy.position_size, 0)),
               text_color=color.gray, text_size=size.tiny)

    // Regime
    table.cell(dbg, 0, 11, "REGIME",   text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 1, 11, _regime,    text_color=color.new(color.blue, 20), text_size=size.tiny)
    table.cell(dbg, 2, 11, sessionStr, text_color=color.gray, text_size=size.tiny)

